<%- include('partials/header', { title: t('join_confirm.page_title'), user }) %>

<div class="card" style="max-width:640px; margin: 0 auto;">
  <h1><%= t('join_confirm.heading', { group_name: group.name }) %></h1>
  <p class="muted"><%= t('join_confirm.intro') %></p>

  <h2><%= t('group.members') %></h2>
  <ul class="list">
    <% members.forEach(member => { %>
      <li>
        <strong><%= member.name %></strong>
        <span class="muted">(<%= member.role %>)</span>
      </li>
    <% }) %>
  </ul>

  <form method="post" action="/join/<%= code %>" style="margin-top:16px;">
    <%- csrfField() %>
    <% if (!group.is_public) { %>
      <label>
        <%= t('group.group_password') %>
        <input type="password" name="password" required />
      </label>
      <% if (error) { %>
        <div class="alert"><%= error %></div>
      <% } %>
    <% } %>
    <div class="inline-actions">
      <button type="submit"><%= t('join_confirm.join_group') %></button>
      <a class="link" href="/dashboard"><%= t('common.cancel') %></a>
    </div>
  </form>
</div>

<%- include('partials/footer') %>
