<%- include('partials/header', { title: t('password_reset.forgot_title'), user: null }) %>

<div class="card" style="max-width:480px; margin: 0 auto;">
  <h1><%= t('password_reset.forgot_heading') %></h1>
  <p class="muted"><%= t('password_reset.forgot_intro') %></p>
  <p class="muted"><%= t('password_reset.check_spam') %></p>
  <% if (error) { %>
    <div class="alert"><%= error %></div>
  <% } %>
  <% if (message) { %>
    <p class="muted"><%= message %></p>
  <% } %>
  <form method="post" action="/forgot-password">
    <label>
      <%= t('common.email') %>
      <input type="email" name="email" placeholder="you@team.com" required />
    </label>
    <button type="submit"><%= t('password_reset.send_reset_link') %></button>
  </form>
</div>

<%- include('partials/footer') %>
