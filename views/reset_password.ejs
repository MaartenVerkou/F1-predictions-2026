<%- include('partials/header', { title: t('password_reset.set_title'), user: null }) %>

<div class="card" style="max-width:480px; margin: 0 auto;">
  <h1><%= t('password_reset.set_heading') %></h1>
  <% if (error) { %>
    <div class="alert"><%= error %></div>
  <% } %>
  <% if (token) { %>
    <form method="post" action="/reset-password">
      <input type="hidden" name="token" value="<%= token %>" />
      <label>
        <%= t('account.new_password') %>
        <input type="password" name="password" minlength="6" required />
      </label>
      <label>
        <%= t('account.confirm_new_password') %>
        <input type="password" name="passwordConfirm" minlength="6" required />
      </label>
      <button type="submit"><%= t('account.update_password') %></button>
    </form>
  <% } %>
</div>

<%- include('partials/footer') %>
