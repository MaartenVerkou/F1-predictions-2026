<%- include('partials/header', { title: t('dashboard.page_title'), user }) %>

<section class="hero dashboard-page">
  <% if (error) { %>
    <div class="alert"><%= error %></div>
  <% } %>
  <% if (success) { %>
    <div class="alert" style="background:#eef8f0;border-color:#c8e6d0;color:#2d6a3a;"><%= success %></div>
  <% } %>

  <div class="hero-main-column">
    <% if (featuredGlobalGroup) { %>
      <div class="card dashboard-mobile-global-card dashboard-group-item dashboard-group-item-featured">
        <div class="dashboard-group-link">
          <div class="dashboard-group-row">
            <div class="dashboard-group-meta">
              <div class="dashboard-group-header-line">
                <strong><%= t('dashboard.global_group_title') %></strong>
                <% if (featuredGlobalGroup.dashboardPosition) { %>
                  <span class="muted dashboard-group-position">
                    <%= t('dashboard.position_summary', { rank: featuredGlobalGroup.dashboardPosition.rank, total: featuredGlobalGroup.dashboardPosition.total }) %>
                  </span>
                <% } %>
              </div>
              <div class="inline-actions dashboard-group-actions">
                <a class="dashboard-group-view-label" href="<%= `${groupPath(featuredGlobalGroup)}/responses` %>"><%= t('responses.page_title') %></a>
                <a class="dashboard-group-view-label" href="<%= `${groupPath(featuredGlobalGroup)}/leaderboard` %>"><%= t('leaderboard.page_title') %></a>
              </div>
            </div>
            <a
              class="dashboard-group-open-btn"
              href="<%= groupPath(featuredGlobalGroup) %>"
              aria-label="<%= `${t('dashboard.view_group')}: ${featuredGlobalGroup.name}` %>"
              title="<%= t('dashboard.view_group') %>"
            >
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M9 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>
    <% } %>

    <section class="card dashboard-my-groups-section">
      <div class="inline-actions" style="justify-content: space-between; align-items: flex-start;">
        <h1 style="margin:0 0 12px 0;"><%= t('dashboard.my_groups') %></h1>
        <div class="inline-actions">
          <a class="button-link dashboard-create-link" href="#create-group" aria-label="<%= t('dashboard.create_group') %>">
            <span class="dashboard-create-link-icon" aria-hidden="true">+</span>
            <span class="dashboard-create-link-label"><%= t('dashboard.create_group') %></span>
          </a>
        </div>
      </div>
      <% if (regularGroups.length === 0) { %>
        <div class="card dashboard-group-item dashboard-empty-card">
          <div class="dashboard-group-link">
            <p class="muted"><%= t('dashboard.no_groups') %></p>
          </div>
        </div>
      <% } %>
      <ul class="list">
        <% regularGroups.forEach(group => { %>
          <li class="card dashboard-group-item">
            <div class="dashboard-group-link">
              <div class="dashboard-group-row">
                <div class="dashboard-group-meta">
                  <div class="dashboard-group-topline">
                    <div class="dashboard-group-titleline">
                      <strong><%= group.name %></strong>
                      <span class="muted dashboard-group-title-meta">
                        <span>(<%= group.role %>)</span>
                        <% if (group.dashboardPosition) { %>
                          <span class="dashboard-group-meta-separator" aria-hidden="true">·</span>
                          <span class="dashboard-group-position dashboard-group-position-inline">
                            <%= t('dashboard.position_summary', { rank: group.dashboardPosition.rank, total: group.dashboardPosition.total }) %>
                          </span>
                        <% } %>
                      </span>
                    </div>
                  </div>
                  <div class="dashboard-group-bottomline">
                    <div class="inline-actions dashboard-group-actions">
                      <a class="dashboard-group-view-label" href="<%= `${groupPath(group)}/responses` %>"><%= t('responses.page_title') %></a>
                      <a class="dashboard-group-view-label" href="<%= `${groupPath(group)}/leaderboard` %>"><%= t('leaderboard.page_title') %></a>
                    </div>
                  </div>
                </div>
                <a
                  class="dashboard-group-open-btn"
                  href="<%= groupPath(group) %>"
                  aria-label="<%= `${t('dashboard.view_group')}: ${group.name}` %>"
                  title="<%= t('dashboard.view_group') %>"
                >
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M9 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>
                </a>
              </div>
            </div>
          </li>
        <% }) %>
      </ul>
      <% if (totalGroupsPages > 1) { %>
        <%- include('partials/admin_pagination', {
          currentPage: currentGroupsPage,
          totalPages: totalGroupsPages,
          pageParamName: 'groupsPage',
          basePath: '/dashboard',
          extraParams: currentPublicGroupsPage > 1 ? { publicGroupsPage: currentPublicGroupsPage } : {},
          showSummary: false,
          maxVisiblePages: 5
        }) %>
      <% } %>
    </section>

    <div class="card" id="public-groups">
      <h2><%= t('dashboard.public_groups') %></h2>
      <% if (!publicGroups || publicGroups.length === 0) { %>
        <p class="muted"><%= t('dashboard.no_public_groups') %></p>
      <% } else { %>
        <ul class="list">
          <% publicGroups.forEach(group => { %>
            <li class="card dashboard-public-group-item">
              <div class="dashboard-group-row dashboard-public-group-row">
                <div class="dashboard-group-meta dashboard-public-group-meta">
                  <div class="dashboard-group-topline">
                    <div class="dashboard-public-group-titleline">
                      <strong><%= group.name %></strong>
                    </div>
                  </div>
                  <% if (!group.is_global) { %>
                    <div class="dashboard-group-bottomline">
                      <span class="muted dashboard-public-group-owner">(<%= t('dashboard.owner') %>: <%= group.owner_name %>)</span>
                    </div>
                  <% } %>
                  <% if (group.is_global) { %>
                    <div class="dashboard-group-bottomline">
                      <span class="muted dashboard-public-group-owner">- <%= t('dashboard.global_group_free') %></span>
                    </div>
                  <% } %>
                </div>
                <form class="dashboard-public-group-join" method="post" action="/groups/<%= group.id %>/join-public" style="margin:0;">
                  <button type="submit"><%= group.is_global ? t('dashboard.join_free') : t('dashboard.join') %></button>
                </form>
              </div>
            </li>
        <% }) %>
      </ul>
      <% if (totalPublicGroupsPages > 1) { %>
        <%- include('partials/admin_pagination', {
          currentPage: currentPublicGroupsPage,
          totalPages: totalPublicGroupsPages,
          pageParamName: 'publicGroupsPage',
          basePath: '/dashboard',
          extraParams: currentGroupsPage > 1 ? { groupsPage: currentGroupsPage } : {},
          showSummary: false,
          maxVisiblePages: 5
        }) %>
      <% } %>
    <% } %>
  </div>

    <div class="card" id="join-group">
      <h2><%= t('dashboard.private_groups') %></h2>
      <p class="muted"><%= t('dashboard.private_groups_help') %></p>
      <form method="post" action="/groups/join">
        <label>
          <%= t('dashboard.group_code') %>
          <input type="text" name="code" required />
        </label>
        <label>
          <%= t('dashboard.group_password') %>
          <input type="password" name="password" required />
        </label>
        <button type="submit"><%= t('dashboard.join_group') %></button>
      </form>
    </div>

    <div class="card" id="create-group">
      <h2><%= t('dashboard.create_new_group') %></h2>
      <form method="post" action="/groups">
        <label>
          <%= t('dashboard.group_name') %>
          <input
            type="text"
            name="name"
            required
            data-name-check-url="/api/groups/check-name"
            data-name-check-delay="2000"
            data-name-check-min-length="2"
            data-name-check-msg-checking="Checking group name..."
            data-name-check-msg-available="Group name is available."
            data-name-check-msg-taken="Group name already exists."
            data-name-check-msg-error="Could not check group name right now."
          />
          <span class="field-status muted" data-name-check-feedback aria-live="polite"></span>
        </label>
        <label>
          <%= t('dashboard.visibility') %>
          <select name="visibility" required>
            <option value="private"><%= t('dashboard.private_option') %></option>
            <option value="public"><%= t('dashboard.public_option') %></option>
          </select>
        </label>
        <label data-private-password-field>
          <%= t('dashboard.group_password_private') %>
          <input type="password" name="joinPassword" minlength="4" />
        </label>
        <button type="submit"><%= t('dashboard.create_group') %></button>
      </form>
    </div>
  </div>

  <%- include('partials/leaderboard_preview', {
    leaderboardCard: globalLeaderboard && Array.isArray(globalLeaderboard.rows) && globalLeaderboard.rows.length > 0
      ? {
          badge: t('home.global_leaderboard_badge'),
          cta: t('leaderboard.full_cta'),
          href: globalLeaderboardHref,
          ariaLabel: t('home.global_leaderboard_badge'),
          rows: globalLeaderboard.rows,
          className: 'dashboard-desktop-global-preview'
        }
      : null
  }) %>
</section>

<%- include('partials/footer') %>
