<%- include('partials/header', { title: t('leaderboard.page_title'), user }) %>

<div class="card survey-page-card">
  <% const driverShortCodeMap = {
    "Alexander Albon": "ALB",
    "Arvid Lindblad": "LIN",
    "Carlos Sainz Jr.": "SAI",
    "Charles Leclerc": "LEC",
    "Esteban Ocon": "OCO",
    "Fernando Alonso": "ALO",
    "Franco Colapinto": "COL",
    "Gabriel Bortoleto": "BOR",
    "George Russell": "RUS",
    "Isack Hadjar": "HAD",
    "Kimi Antonelli": "ANT",
    "Lance Stroll": "STR",
    "Lando Norris": "NOR",
    "Lewis Hamilton": "HAM",
    "Liam Lawson": "LAW",
    "Max Verstappen": "VER",
    "Nico Hulkenberg": "HUL",
    "Oliver Bearman": "BEA",
    "Oscar Piastri": "PIA",
    "Pierre Gasly": "GAS",
    "Sergio Perez": "PER",
    "Valtteri Bottas": "BOT"
  }; %>
  <% const teamShortCodeMap = {
    "Alpine": "ALP",
    "Aston Martin": "AST",
    "Audi": "AUD",
    "Cadillac": "CAD",
    "Ferrari": "FER",
    "Haas F1 Team": "HAA",
    "McLaren": "MCL",
    "Mercedes": "MER",
    "Racing Bulls": "RBT",
    "Red Bull Racing": "RBR",
    "Williams": "WIL"
  }; %>
  <% const raceShortCodeMap = {
    "Australian Grand Prix": "AUS",
    "Chinese Grand Prix": "CHN",
    "Japanese Grand Prix": "JPN",
    "Bahrain Grand Prix": "BHR",
    "Saudi Arabian Grand Prix": "SAU",
    "Miami Grand Prix": "MIA",
    "Canadian Grand Prix": "CAN",
    "Monaco Grand Prix": "MON",
    "Barcelona-Catalunya Grand Prix": "CAT",
    "Austrian Grand Prix": "AUT",
    "British Grand Prix": "GBR",
    "Belgian Grand Prix": "BEL",
    "Hungarian Grand Prix": "HUN",
    "Dutch Grand Prix": "NED",
    "Italian Grand Prix": "ITA",
    "Spanish Grand Prix": "ESP",
    "Azerbaijan Grand Prix": "AZE",
    "Singapore Grand Prix": "SIN",
    "United States Grand Prix": "USA",
    "Mexico City Grand Prix": "MEX",
    "Sao Paulo Grand Prix": "BRA",
    "Las Vegas Grand Prix": "LVG",
    "Qatar Grand Prix": "QAT",
    "Abu Dhabi Grand Prix": "ABD"
  }; %>
  <% const escapeRegExp = (value) => String(value || "").replace(/[.*+?^${}()|[\]\\]/g, "\\$&"); %>
  <% const shortRaceCode = (race) => raceShortCodeMap[String(race || "").trim()] || String(race || ""); %>
  <% const abbreviateEntities = (text) => {
    let output = String(text || "");
    const entries = Object.entries({ ...teamShortCodeMap, ...driverShortCodeMap })
      .sort((a, b) => b[0].length - a[0].length);
    entries.forEach(([label, code]) => {
      output = output.replace(new RegExp(escapeRegExp(label), "g"), code);
    });
    return output;
  }; %>
  <% const shouldPreferCompactValue = (question, raw, display) => {
    if (!question || raw == null || raw === "" || !display || display === "-") return false;
    if (question.id === "select_three_races_dnfs") return true;

    const text = String(raw).trim();
    if (text.startsWith("[")) {
      try {
        const parsed = JSON.parse(text);
        return Array.isArray(parsed) && parsed.length > 1;
      } catch (err) {}
    }

    return false;
  }; %>
  <% const formatInlineValue = (value) => {
    if (value == null || value === "") return "-";
    if (Array.isArray(value)) return value.join(" | ");
    if (typeof value === "object") {
      return Object.entries(value)
        .map(([key, inner]) => `${key}: ${formatInlineValue(inner)}`)
        .join("; ");
    }
    return String(value);
  }; %>
  <% const formatValue = (question, raw) => {
    if (raw == null || raw === "") return "-";
    const text = String(raw);
    const type = question?.type || "text";
    const looksJson = text.startsWith("[") || text.startsWith("{");
    if (
      type === "ranking" ||
      type === "multi_select" ||
      type === "multi_select_limited" ||
      type === "teammate_battle" ||
      type === "boolean_with_optional_driver" ||
      type === "numeric_with_driver" ||
      type === "single_choice_with_driver" ||
      looksJson
    ) {
      try {
        const parsed = JSON.parse(text);
        if (question?.id === "select_three_races_dnfs") {
          if (Array.isArray(parsed)) {
            return parsed.map(shortRaceCode).join(" | ") || "-";
          }
          const dnfByRace = parsed?.dnf_by_race;
          if (dnfByRace && typeof dnfByRace === "object") {
            const parts = Object.entries(dnfByRace)
              .filter(([, count]) => Number(count) > 0)
              .map(([race, count]) => `${shortRaceCode(race)}: ${count}`);
            return parts.join(" | ") || "-";
          }
        }
        if (Array.isArray(parsed)) return parsed.join(" | ");
        if (parsed && typeof parsed === "object") {
          if (type === "teammate_battle") {
            if (parsed.winner === "tie") return "Tie";
            if (parsed.winner) {
              const diffText =
                parsed.diff == null || parsed.diff === ""
                  ? ""
                  : ` (${parsed.diff})`;
              return `${parsed.winner}${diffText}`;
            }
          }
          if (type === "boolean_with_optional_driver") {
            const choice = parsed.choice == null ? "-" : String(parsed.choice);
            return parsed.driver ? `${choice} - ${parsed.driver}` : choice;
          }
          if (type === "numeric_with_driver" || type === "single_choice_with_driver") {
            const value = parsed.value == null ? "-" : String(parsed.value);
            return parsed.driver ? `${value} - ${parsed.driver}` : value;
          }
          return formatInlineValue(parsed);
        }
        return parsed == null ? "-" : String(parsed);
      } catch (err) {
        return text;
      }
    }
    return text;
  }; %>
  <% const leaderboardBaseHref =
    typeof leaderboardBasePath === "string" && leaderboardBasePath
      ? leaderboardBasePath
      : groupPath(group, "/leaderboard"); %>
  <% const currentGroupPath =
    typeof groupBasePath === "string" && groupBasePath
      ? groupBasePath
      : (leaderboardBaseHref.endsWith("/leaderboard")
          ? leaderboardBaseHref.replace(/\/leaderboard$/, "")
          : groupPath(group)); %>
  <% const leaderboardQueryPart =
    typeof leaderboardQuery === "string" && leaderboardQuery.trim()
      ? leaderboardQuery.trim()
      : ""; %>
  <% const leaderboardExtraParams = {}; %>
  <% if (leaderboardQueryPart) { %>
    <% for (const [key, value] of new URLSearchParams(leaderboardQueryPart).entries()) { %>
      <% leaderboardExtraParams[key] = value; %>
    <% } %>
  <% } %>
  <% const snapshotFilterParams = {}; %>
  <% for (const [key, value] of Object.entries(leaderboardExtraParams)) { %>
    <% if (key === "page" || key === "snapshot") continue; %>
    <% snapshotFilterParams[key] = value; %>
  <% } %>
  <% const selectedSnapshotKey =
    selectedActualSnapshotId == null ? "" : String(selectedActualSnapshotId); %>

  <div class="page-title-row">
    <h1><%= group.name %>: <%= t('leaderboard.page_title') %></h1>
    <a class="link page-back-link" href="<%= currentGroupPath %>">&lt; <%= t('group.back_to_group') %></a>
  </div>

  <% if (Object.keys(actuals || {}).length === 0) { %>
    <div class="alert"><%= t('leaderboard.no_actuals') %></div>
  <% } %>

  <% if (leaderboard.length === 0) { %>
    <div class="alert"><%= t('leaderboard.no_scored_responses') %></div>
  <% } else { %>
    <% const startRank = (currentLeaderboardPage - 1) * leaderboardPerPage + 1; %>
    <% const endRank = startRank + leaderboard.length - 1; %>

    <div id="leaderboard-overview" class="leaderboard-layout">
      <div class="leaderboard-main-column">
        <% if ((actualSnapshots || []).length > 0) { %>
          <form method="get" action="<%= leaderboardBaseHref %>" class="leaderboard-snapshot-form inline-actions">
            <% Object.entries(snapshotFilterParams).forEach(([key, value]) => { %>
              <input type="hidden" name="<%= key %>" value="<%= value %>" />
            <% }) %>
            <select
              id="snapshot-select"
              name="snapshot"
              aria-label="<%= t('leaderboard.snapshot_label') %>"
              onchange="this.form.submit()"
            >
              <option value="" <%= selectedSnapshotKey === "" ? "selected" : "" %>><%= t('leaderboard.current_snapshot') %></option>
              <% actualSnapshots.forEach((snapshot) => { %>
                <option value="<%= snapshot.id %>" <%= selectedSnapshotKey === String(snapshot.id) ? "selected" : "" %>>
                  <%= snapshot.label %>
                </option>
              <% }) %>
            </select>
            <noscript><button type="submit" class="secondary"><%= t('leaderboard.apply_snapshot') %></button></noscript>
          </form>
        <% } %>

        <section class="leaderboard-main-card">
          <table class="table">
            <thead>
              <tr>
                <th>
                  <span class="leaderboard-header-long">POSITION</span>
                  <span class="leaderboard-header-short">POS.</span>
                </th>
                <th>NAME</th>
                <th>
                  <span class="leaderboard-header-long">POINTS</span>
                  <span class="leaderboard-header-short">PTS</span>
                </th>
              </tr>
            </thead>
            <tbody>
              <% leaderboard.forEach((row, index) => { %>
                <% const panelId = `leaderboard-member-panel-${row.userId}`; %>
                <tr
                  class="leaderboard-rank-row <%= index === 0 ? 'is-active' : '' %>"
                  data-member-activate="<%= panelId %>"
                  tabindex="0"
                  role="button"
                  aria-controls="<%= panelId %>"
                  aria-pressed="<%= index === 0 ? 'true' : 'false' %>"
                >
                  <td><%= row.rank %></td>
                  <td><strong><%= row.name %></strong></td>
                  <td><strong><%= row.total %></strong></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
          <p class="muted" style="margin: 10px 0 0;">
            <%= t('leaderboard.showing_range', { start: startRank, end: endRank, total: leaderboardTotal }) %>
          </p>
          <%- include('partials/admin_pagination', {
            currentPage: currentLeaderboardPage,
            totalPages: totalLeaderboardPages,
            pageParamName: 'page',
            basePath: leaderboardBaseHref,
            extraParams: leaderboardExtraParams,
            anchorId: 'leaderboard-overview',
            label: t('leaderboard.page_title'),
            perPage: leaderboardPerPage,
            showSummary: false
          }) %>
        </section>
      </div>

      <section class="leaderboard-detail-card">
        <% leaderboard.forEach((row, index) => { %>
          <% const panelId = `leaderboard-member-panel-${row.userId}`; %>
          <section
            id="<%= panelId %>"
            class="leaderboard-member-panel <%= index === 0 ? 'is-active' : '' %>"
            <%= index === 0 ? '' : 'hidden' %>
          >
            <table class="table compact leaderboard-breakdown-table">
              <thead>
                <tr>
                  <th>Q</th>
                  <th><%= t('leaderboard.prediction') %></th>
                  <th><%= t('leaderboard.actual') %></th>
                  <th><%= t('leaderboard.points_short_caps') %></th>
                </tr>
              </thead>
              <tbody>
              <% questions.forEach((q, questionIndex) => { %>
                <tr>
                  <td>
                    <span class="leaderboard-question-chip" tabindex="0">
                      <span class="leaderboard-question-code">Q<%= questionIndex + 1 %></span>
                      <span class="leaderboard-question-tooltip"><%= q.prompt %></span>
                    </span>
                  </td>
                  <% const actualDisplay = formatValue(q, actuals?.[q.id]); %>
                  <% const answerDisplay = formatValue(q, row.answersByQuestion?.[q.id]); %>
                  <td>
                    <span class="leaderboard-value-cell <%= shouldPreferCompactValue(q, row.answersByQuestion?.[q.id], answerDisplay) ? 'has-short' : '' %>">
                      <span class="leaderboard-value-full"><%= answerDisplay %></span>
                      <span class="leaderboard-value-short"><%= abbreviateEntities(answerDisplay) %></span>
                    </span>
                  </td>
                  <td>
                    <span class="leaderboard-value-cell <%= shouldPreferCompactValue(q, actuals?.[q.id], actualDisplay) ? 'has-short' : '' %>">
                      <span class="leaderboard-value-full"><%= actualDisplay %></span>
                      <span class="leaderboard-value-short"><%= abbreviateEntities(actualDisplay) %></span>
                    </span>
                  </td>
                  <td><strong><%= row.byQuestion[q.id] ?? 0 %></strong></td>
                </tr>
              <% }) %>
              </tbody>
            </table>
          </section>
        <% }) %>
      </section>
    </div>
  <% } %>
</div>

<%- include('partials/footer') %>
