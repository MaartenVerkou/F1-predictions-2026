<%- include('partials/header', { title: t('leaderboard.page_title'), user }) %>

<div class="card survey-page-card">
  <% const driverShortCodeMap = {
    "Alexander Albon": "ALB",
    "Arvid Lindblad": "LIN",
    "Carlos Sainz Jr.": "SAI",
    "Charles Leclerc": "LEC",
    "Esteban Ocon": "OCO",
    "Fernando Alonso": "ALO",
    "Franco Colapinto": "COL",
    "Gabriel Bortoleto": "BOR",
    "George Russell": "RUS",
    "Isack Hadjar": "HAD",
    "Kimi Antonelli": "ANT",
    "Lance Stroll": "STR",
    "Lando Norris": "NOR",
    "Lewis Hamilton": "HAM",
    "Liam Lawson": "LAW",
    "Max Verstappen": "VER",
    "Nico Hulkenberg": "HUL",
    "Oliver Bearman": "BEA",
    "Oscar Piastri": "PIA",
    "Pierre Gasly": "GAS",
    "Sergio Perez": "PER",
    "Valtteri Bottas": "BOT"
  }; %>
  <% const teamShortCodeMap = {
    "Alpine": "ALP",
    "Aston Martin": "AST",
    "Audi": "AUD",
    "Cadillac": "CAD",
    "Ferrari": "FER",
    "Haas F1 Team": "HAA",
    "McLaren": "MCL",
    "Mercedes": "MER",
    "Racing Bulls": "RBT",
    "Red Bull Racing": "RBR",
    "Williams": "WIL"
  }; %>
  <% const raceShortCodeMap = {
    "Australian Grand Prix": "AUS",
    "Chinese Grand Prix": "CHN",
    "Japanese Grand Prix": "JPN",
    "Bahrain Grand Prix": "BHR",
    "Saudi Arabian Grand Prix": "SAU",
    "Miami Grand Prix": "MIA",
    "Canadian Grand Prix": "CAN",
    "Monaco Grand Prix": "MON",
    "Barcelona-Catalunya Grand Prix": "CAT",
    "Austrian Grand Prix": "AUT",
    "British Grand Prix": "GBR",
    "Belgian Grand Prix": "BEL",
    "Hungarian Grand Prix": "HUN",
    "Dutch Grand Prix": "NED",
    "Italian Grand Prix": "ITA",
    "Spanish Grand Prix": "ESP",
    "Azerbaijan Grand Prix": "AZE",
    "Singapore Grand Prix": "SIN",
    "United States Grand Prix": "USA",
    "Mexico City Grand Prix": "MEX",
    "Sao Paulo Grand Prix": "BRA",
    "Las Vegas Grand Prix": "LVG",
    "Qatar Grand Prix": "QAT",
    "Abu Dhabi Grand Prix": "ABD"
  }; %>
  <% const escapeRegExp = (value) => String(value || "").replace(/[.*+?^${}()|[\]\\]/g, "\\$&"); %>
  <% const shortRaceCode = (race) => raceShortCodeMap[String(race || "").trim()] || String(race || ""); %>
  <% const abbreviateEntities = (text) => {
    let output = String(text || "");
    const entries = Object.entries({ ...teamShortCodeMap, ...driverShortCodeMap })
      .sort((a, b) => b[0].length - a[0].length);
    entries.forEach(([label, code]) => {
      output = output.replace(new RegExp(escapeRegExp(label), "g"), code);
    });
    return output;
  }; %>
  <% const shouldPreferCompactValue = (question, raw, display) => {
    if (!question || raw == null || raw === "" || !display || display === "-") return false;
    if (question.id === "select_three_races_dnfs") return true;

    const text = String(raw).trim();
    if (text.startsWith("[")) {
      try {
        const parsed = JSON.parse(text);
        return Array.isArray(parsed) && parsed.length > 1;
      } catch (err) {}
    }

    return false;
  }; %>
  <% const formatInlineValue = (value) => {
    if (value == null || value === "") return "-";
    if (Array.isArray(value)) return value.join(" | ");
    if (typeof value === "object") {
      return Object.entries(value)
        .map(([key, inner]) => `${key}: ${formatInlineValue(inner)}`)
        .join("; ");
    }
    return String(value);
  }; %>
  <% const formatValue = (question, raw) => {
    if (raw == null || raw === "") return "-";
    const text = String(raw);
    const type = question?.type || "text";
    const looksJson = text.startsWith("[") || text.startsWith("{");
    if (
      type === "ranking" ||
      type === "multi_select" ||
      type === "multi_select_limited" ||
      type === "teammate_battle" ||
      type === "boolean_with_optional_driver" ||
      type === "numeric_with_driver" ||
      type === "single_choice_with_driver" ||
      looksJson
    ) {
      try {
        const parsed = JSON.parse(text);
        if (question?.id === "select_three_races_dnfs") {
          if (Array.isArray(parsed)) {
            return parsed.map(shortRaceCode).join(" | ") || "-";
          }
          const dnfByRace = parsed?.dnf_by_race;
          if (dnfByRace && typeof dnfByRace === "object") {
            const parts = Object.entries(dnfByRace)
              .filter(([, count]) => Number(count) > 0)
              .map(([race, count]) => `${shortRaceCode(race)}: ${count}`);
            return parts.join(" | ") || "-";
          }
        }
        if (Array.isArray(parsed)) return parsed.join(" | ");
        if (parsed && typeof parsed === "object") {
          if (type === "teammate_battle") {
            if (parsed.winner === "tie") return "Tie";
            if (parsed.winner) {
              const diffText =
                parsed.diff == null || parsed.diff === ""
                  ? ""
                  : ` (${parsed.diff})`;
              return `${parsed.winner}${diffText}`;
            }
          }
          if (type === "boolean_with_optional_driver") {
            const choice = parsed.choice == null ? "-" : String(parsed.choice);
            return parsed.driver ? `${choice} - ${parsed.driver}` : choice;
          }
          if (type === "numeric_with_driver" || type === "single_choice_with_driver") {
            const value = parsed.value == null ? "-" : String(parsed.value);
            return parsed.driver ? `${value} - ${parsed.driver}` : value;
          }
          return formatInlineValue(parsed);
        }
        return parsed == null ? "-" : String(parsed);
      } catch (err) {
        return text;
      }
    }
    return text;
  }; %>
  <% const leaderboardBaseHref =
    typeof leaderboardBasePath === "string" && leaderboardBasePath
      ? leaderboardBasePath
      : groupPath(group, "/leaderboard"); %>
  <% const currentGroupPath =
    typeof groupBasePath === "string" && groupBasePath
      ? groupBasePath
      : (leaderboardBaseHref.endsWith("/leaderboard")
          ? leaderboardBaseHref.replace(/\/leaderboard$/, "")
          : groupPath(group)); %>
  <% const leaderboardQueryPart =
    typeof leaderboardQuery === "string" && leaderboardQuery.trim()
      ? leaderboardQuery.trim()
      : ""; %>
  <% const leaderboardExtraParams = {}; %>
  <% if (leaderboardQueryPart) { %>
    <% for (const [key, value] of new URLSearchParams(leaderboardQueryPart).entries()) { %>
      <% leaderboardExtraParams[key] = value; %>
    <% } %>
  <% } %>
  <% const snapshotFilterParams = {}; %>
  <% for (const [key, value] of Object.entries(leaderboardExtraParams)) { %>
    <% if (key === "page" || key === "snapshot") continue; %>
    <% snapshotFilterParams[key] = value; %>
  <% } %>
  <% const selectedSnapshotKey =
    selectedActualSnapshotId == null ? "" : String(selectedActualSnapshotId); %>
  <% const safeHistory = leaderboardHistory || { hasEnoughHistory: false, rounds: [], series: [], maxTotal: 0 }; %>
  <% const safeInsights = participantInsights || { selectedParticipant: null, comparisonRows: [], gaps: [], strengths: [], distinctive: [], emptyReason: null }; %>
  <% const safeBreakdown = selectedBreakdown || { mode: 'scored', hasScoredRows: false, rows: [] }; %>
  <% const selectedParticipantKey = selectedParticipantId == null ? "" : String(selectedParticipantId); %>
  <% const currentUserKey = user && user.id != null ? String(user.id) : ""; %>
  <% const safeLatestRoundDeltaMeta = latestRoundDeltaMeta || null; %>
  <% const hasRoundDeltaColumn = Boolean(safeLatestRoundDeltaMeta); %>
  <% const leaderboardHref = (updates = {}, anchor = 'leaderboard-overview') => {
    const params = new URLSearchParams(leaderboardQueryPart);
    params.delete('page');
    Object.entries(updates).forEach(([key, value]) => {
      if (value == null || value === '') params.delete(key);
      else params.set(key, String(value));
    });
    const query = params.toString();
    return `${leaderboardBaseHref}${query ? `?${query}` : ''}${anchor ? `#${anchor}` : ''}`;
  }; %>
  <% const formatSigned = (value) => {
    const number = Number(value || 0);
    if (!Number.isFinite(number) || number === 0) return '0';
    return number > 0 ? `+${number}` : String(number);
  }; %>
  <% const formatRankDelta = (value) => {
    const number = Number(value || 0);
    if (!Number.isFinite(number) || number === 0) return 'steady';
    return number > 0 ? `+${number} rank` : `${number} rank`;
  }; %>
  <% const truncatePrompt = (value) => {
    const text = String(value || '');
    return text.length > 90 ? `${text.slice(0, 87)}...` : text;
  }; %>
  <% const chartPalette = [
    '#455a64',
    '#1f7a8c',
    '#6c5ce7',
    '#2b6f3e',
    '#8a6d3b',
    '#3867d6',
    '#ad1457',
    '#00766c',
    '#725ac1',
    '#c44d00',
    '#5f6f52',
    '#7b4f86'
  ]; %>

  <div class="page-title-row">
    <h1><%= group.name %>: <%= t('leaderboard.page_title') %></h1>
    <a class="link page-back-link" href="<%= currentGroupPath %>">&lt; <%= t('group.back_to_group') %></a>
  </div>

  <% if (Object.keys(actuals || {}).length === 0) { %>
    <div class="alert"><%= t('leaderboard.no_actuals') %></div>
  <% } %>

  <% if (leaderboard.length === 0) { %>
    <div class="alert"><%= t('leaderboard.no_scored_responses') %></div>
  <% } else { %>
    <% const startRank = (currentLeaderboardPage - 1) * leaderboardPerPage + 1; %>
    <% const endRank = startRank + leaderboard.length - 1; %>

    <section class="leaderboard-insights-overview" aria-label="Leaderboard insights">
      <section class="leaderboard-trend-panel">
        <div class="leaderboard-section-heading">
          <div>
            <h2>Points over rounds</h2>
            <p class="muted">
              Top 10 plus selected participants.
              <% if (hasRoundDeltaColumn) { %>
                Last race: R<%= safeLatestRoundDeltaMeta.previousRound.roundNumber %> to R<%= safeLatestRoundDeltaMeta.latestRound.roundNumber %>.
              <% } %>
            </p>
          </div>
        </div>
        <% if (safeHistory.hasEnoughHistory && safeHistory.series.length > 0) { %>
          <% const chartWidth = 720; %>
          <% const chartHeight = 260; %>
          <% const padLeft = 46; %>
          <% const padRight = 18; %>
          <% const padTop = 18; %>
          <% const padBottom = 42; %>
          <% const plotWidth = chartWidth - padLeft - padRight; %>
          <% const plotHeight = chartHeight - padTop - padBottom; %>
          <% const maxTotal = Math.max(1, Number(safeHistory.maxTotal || 0)); %>
          <% const xForIndex = (idx) => safeHistory.rounds.length <= 1
            ? padLeft
            : padLeft + (idx / (safeHistory.rounds.length - 1)) * plotWidth; %>
          <% const yForTotal = (total) => padTop + plotHeight - (Number(total || 0) / maxTotal) * plotHeight; %>
          <div class="leaderboard-chart-wrap">
            <svg
              class="leaderboard-trend-chart"
              viewBox="0 0 <%= chartWidth %> <%= chartHeight %>"
              role="img"
              aria-label="Leaderboard points over completed rounds"
            >
              <line x1="<%= padLeft %>" y1="<%= padTop %>" x2="<%= padLeft %>" y2="<%= padTop + plotHeight %>" class="leaderboard-chart-axis" />
              <line x1="<%= padLeft %>" y1="<%= padTop + plotHeight %>" x2="<%= padLeft + plotWidth %>" y2="<%= padTop + plotHeight %>" class="leaderboard-chart-axis" />
              <% [0, 0.5, 1].forEach((tick) => { %>
                <% const y = padTop + plotHeight - tick * plotHeight; %>
                <line x1="<%= padLeft %>" y1="<%= y %>" x2="<%= padLeft + plotWidth %>" y2="<%= y %>" class="leaderboard-chart-grid" />
                <text x="<%= padLeft - 10 %>" y="<%= y + 4 %>" text-anchor="end" class="leaderboard-chart-label"><%= Math.round(maxTotal * tick) %></text>
              <% }) %>
              <% safeHistory.rounds.forEach((round, idx) => { %>
                <% const x = xForIndex(idx); %>
                <text x="<%= x %>" y="<%= chartHeight - 14 %>" text-anchor="middle" class="leaderboard-chart-label">R<%= round.roundNumber %></text>
              <% }) %>
              <% safeHistory.series.forEach((series, seriesIndex) => { %>
                <% const isSelected = String(series.participantId) === selectedParticipantKey; %>
                <% const isCurrentUser = currentUserKey && String(series.participantId) === currentUserKey; %>
                <% const cssClass = `leaderboard-chart-line ${isSelected ? 'is-selected' : ''} ${isCurrentUser ? 'is-current-user' : ''}`; %>
                <% const pointsAttr = series.points.map((point, idx) => `${xForIndex(idx).toFixed(2)},${yForTotal(point.total).toFixed(2)}`).join(' '); %>
                <% const seriesColor = chartPalette[seriesIndex % chartPalette.length]; %>
                <polyline class="<%= cssClass %>" points="<%= pointsAttr %>" style="--series-index:<%= seriesIndex %>; --chart-line-color:<%= seriesColor %>;" />
                <% series.points.forEach((point, idx) => { %>
                  <% const x = xForIndex(idx); %>
                  <% const y = yForTotal(point.total); %>
                  <circle class="<%= cssClass %>" cx="<%= x %>" cy="<%= y %>" r="<%= isSelected || isCurrentUser ? 4 : 2.8 %>" style="--series-index:<%= seriesIndex %>; --chart-line-color:<%= seriesColor %>;">
                    <title><%= `${series.name}: ${point.total} points after R${point.roundNumber}${point.rank ? `, rank ${point.rank}` : ''}` %></title>
                  </circle>
                <% }) %>
              <% }) %>
            </svg>
          </div>
          <div class="leaderboard-chart-legend" aria-label="Plotted participants">
            <% safeHistory.series.forEach((series, seriesIndex) => { %>
              <% const isSelected = String(series.participantId) === selectedParticipantKey; %>
              <% const isCurrentUser = currentUserKey && String(series.participantId) === currentUserKey; %>
              <a
                class="leaderboard-chart-legend-item <%= isSelected ? 'is-selected' : '' %> <%= isCurrentUser ? 'is-current-user' : '' %>"
                href="<%= leaderboardHref({ participant: series.participantId }) %>"
                style="--series-index:<%= seriesIndex %>; --chart-line-color:<%= chartPalette[seriesIndex % chartPalette.length] %>;"
              >
                <span class="leaderboard-legend-swatch"></span>
                <span><%= series.name %></span>
                <% const latestPoint = series.points[series.points.length - 1]; %>
                <% if (latestPoint) { %>
                  <strong><%= latestPoint.total %></strong>
                <% } %>
              </a>
            <% }) %>
          </div>
        <% } else { %>
          <p class="muted leaderboard-empty-copy">Trends will appear after two race snapshots are available.</p>
        <% } %>
      </section>

    </section>

    <div id="leaderboard-overview" class="leaderboard-layout">
      <div class="leaderboard-main-column">
        <% if ((actualSnapshots || []).length > 0) { %>
          <form method="get" action="<%= leaderboardBaseHref %>" class="leaderboard-snapshot-form inline-actions">
            <% Object.entries(snapshotFilterParams).forEach(([key, value]) => { %>
              <input type="hidden" name="<%= key %>" value="<%= value %>" />
            <% }) %>
            <select
              id="snapshot-select"
              name="snapshot"
              aria-label="<%= t('leaderboard.snapshot_label') %>"
              onchange="this.form.submit()"
            >
              <option value="" <%= selectedSnapshotKey === "" ? "selected" : "" %>><%= t('leaderboard.current_snapshot') %></option>
              <% actualSnapshots.forEach((snapshot) => { %>
                <option value="<%= snapshot.id %>" <%= selectedSnapshotKey === String(snapshot.id) ? "selected" : "" %>>
                  <%= snapshot.label %><%= snapshot.reviewStatus === 'pending' ? ' | pending review' : '' %>
                </option>
              <% }) %>
            </select>
            <noscript><button type="submit" class="secondary"><%= t('leaderboard.apply_snapshot') %></button></noscript>
          </form>
        <% } %>

        <section class="leaderboard-main-card">
          <table class="table">
            <thead>
              <tr>
                <th>
                  <span class="leaderboard-header-long">POSITION</span>
                  <span class="leaderboard-header-short">POS.</span>
                </th>
                <th>NAME</th>
                <th>
                  <span class="leaderboard-header-long">POINTS</span>
                  <span class="leaderboard-header-short">PTS</span>
                </th>
                <% if (hasRoundDeltaColumn) { %>
                  <th>
                    <span class="leaderboard-header-long">LAST RACE</span>
                    <span class="leaderboard-header-short">LAST</span>
                  </th>
                <% } %>
              </tr>
            </thead>
            <tbody>
              <% leaderboard.forEach((row, index) => { %>
                <tr
                  class="leaderboard-rank-row <%= String(row.userId) === selectedParticipantKey ? 'is-active' : '' %>"
                >
                  <td><%= row.rank %></td>
                  <td>
                    <a class="leaderboard-row-link" href="<%= leaderboardHref({ participant: row.userId }) %>">
                      <strong><%= row.name %></strong>
                    </a>
                  </td>
                  <td><strong><%= row.total %></strong></td>
                  <% if (hasRoundDeltaColumn) { %>
                    <% const delta = row.latestRoundDelta; %>
                    <td class="leaderboard-delta-cell">
                      <% if (delta) { %>
                        <% const deltaClass = Number(delta.pointsDelta || 0) > 0 ? 'is-positive' : (Number(delta.pointsDelta || 0) < 0 ? 'is-negative' : ''); %>
                        <strong class="<%= deltaClass %>"><%= formatSigned(delta.pointsDelta) %> pts</strong>
                        <span class="muted"><%= formatRankDelta(delta.rankDelta) %></span>
                      <% } else { %>
                        <span class="muted">-</span>
                      <% } %>
                    </td>
                  <% } %>
                </tr>
              <% }) %>
            </tbody>
          </table>
          <p class="muted" style="margin: 10px 0 0;">
            <%= t('leaderboard.showing_range', { start: startRank, end: endRank, total: leaderboardTotal }) %>
          </p>
          <%- include('partials/admin_pagination', {
            currentPage: currentLeaderboardPage,
            totalPages: totalLeaderboardPages,
            pageParamName: 'page',
            basePath: leaderboardBaseHref,
            extraParams: leaderboardExtraParams,
            anchorId: 'leaderboard-overview',
            label: t('leaderboard.page_title'),
            perPage: leaderboardPerPage,
            showSummary: false
          }) %>
        </section>
      </div>

      <section class="leaderboard-detail-card">
        <section class="leaderboard-member-panel leaderboard-selected-panel">
          <% if (safeInsights.selectedParticipant) { %>
            <div class="leaderboard-member-heading">
              <div>
                <h2><%= safeInsights.selectedParticipant.name %></h2>
                <p class="muted">
                  Rank <strong><%= safeInsights.selectedParticipant.rank %></strong>
                  - <strong><%= safeInsights.selectedParticipant.total %></strong> points
                </p>
              </div>
            </div>

            <div class="leaderboard-insight-grid">
              <section>
                <h3>Gaps above</h3>
                <% if (safeInsights.gaps.length > 0) { %>
                  <ul class="leaderboard-insight-list">
                    <% safeInsights.gaps.forEach((item) => { %>
                      <li>
                        <strong><%= formatSigned(-item.difference) %> pts</strong>
                        <span><%= truncatePrompt(item.prompt) %></span>
                      </li>
                    <% }) %>
                  </ul>
                <% } else { %>
                  <p class="muted">No clear scored gap to nearby rivals yet.</p>
                <% } %>
              </section>

              <section>
                <h3>Strengths</h3>
                <% if (safeInsights.strengths.length > 0) { %>
                  <ul class="leaderboard-insight-list">
                    <% safeInsights.strengths.forEach((item) => { %>
                      <li>
                        <strong><%= formatSigned(item.difference) %> pts</strong>
                        <span><%= truncatePrompt(item.prompt) %></span>
                      </li>
                    <% }) %>
                  </ul>
                <% } else { %>
                  <p class="muted">No standout scored edge in the nearby band yet.</p>
                <% } %>
              </section>

              <section class="leaderboard-insight-wide">
                <h3>Distinctive picks</h3>
                <% if (safeInsights.distinctive.length > 0) { %>
                  <ul class="leaderboard-insight-list">
                    <% safeInsights.distinctive.forEach((item) => { %>
                      <li>
                        <strong><%= item.selectedPoints %> pts</strong>
                        <span><%= truncatePrompt(item.prompt) %></span>
                      </li>
                    <% }) %>
                  </ul>
                <% } else { %>
                  <p class="muted"><%= safeInsights.emptyReason || 'No distinctive scoring pattern in the nearby band yet.' %></p>
                <% } %>
              </section>
            </div>

            <div class="leaderboard-breakdown-header">
              <div>
                <h3>Question breakdown</h3>
                <p class="muted"><%= safeBreakdown.mode === 'all' ? 'All questions' : 'Scored questions' %></p>
              </div>
              <div class="leaderboard-breakdown-toggle" aria-label="Question breakdown filter">
                <a class="<%= safeBreakdown.mode === 'scored' ? 'is-active' : '' %>" href="<%= leaderboardHref({ breakdown: '' }, 'leaderboard-breakdown') %>">Scored</a>
                <a class="<%= safeBreakdown.mode === 'all' ? 'is-active' : '' %>" href="<%= leaderboardHref({ breakdown: 'all' }, 'leaderboard-breakdown') %>">All</a>
              </div>
            </div>

            <div id="leaderboard-breakdown">
              <% if (safeBreakdown.rows.length > 0) { %>
                <table class="table compact leaderboard-breakdown-table">
                  <thead>
                    <tr>
                      <th>Q</th>
                      <th><%= t('leaderboard.prediction') %></th>
                      <th><%= t('leaderboard.actual') %></th>
                      <th><%= t('leaderboard.points_short_caps') %></th>
                    </tr>
                  </thead>
                  <tbody>
                  <% safeBreakdown.rows.forEach((breakdownRow) => { %>
                    <% const q = breakdownRow.question; %>
                    <% const actualDisplay = formatValue(q, breakdownRow.actualRaw); %>
                    <% const answerDisplay = formatValue(q, breakdownRow.predictionRaw); %>
                    <tr class="<%= breakdownRow.isScored ? '' : 'is-unscored' %>">
                      <td>
                        <span class="leaderboard-question-chip" tabindex="0">
                          <span class="leaderboard-question-code">Q<%= breakdownRow.questionNumber %></span>
                          <span class="leaderboard-question-tooltip"><%= q.prompt %></span>
                        </span>
                      </td>
                      <td>
                        <span class="leaderboard-value-cell <%= shouldPreferCompactValue(q, breakdownRow.predictionRaw, answerDisplay) ? 'has-short' : '' %>">
                          <span class="leaderboard-value-full"><%= answerDisplay %></span>
                          <span class="leaderboard-value-short"><%= abbreviateEntities(answerDisplay) %></span>
                        </span>
                      </td>
                      <td>
                        <span class="leaderboard-value-cell <%= shouldPreferCompactValue(q, breakdownRow.actualRaw, actualDisplay) ? 'has-short' : '' %>">
                          <span class="leaderboard-value-full"><%= actualDisplay %></span>
                          <span class="leaderboard-value-short"><%= abbreviateEntities(actualDisplay) %></span>
                        </span>
                      </td>
                      <td><strong><%= breakdownRow.points %></strong></td>
                    </tr>
                  <% }) %>
                  </tbody>
                </table>
              <% } else { %>
                <p class="muted leaderboard-empty-copy">
                  <%= safeBreakdown.mode === 'scored' ? 'No scored questions for this participant yet.' : 'No question answers found for this participant.' %>
                </p>
              <% } %>
            </div>
          <% } else { %>
            <p class="muted leaderboard-empty-copy">Select a scored participant to see leaderboard insights.</p>
          <% } %>
        </section>
      </section>
    </div>
  <% } %>
</div>

<%- include('partials/footer') %>
