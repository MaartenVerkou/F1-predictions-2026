<%- include('partials/header', { title: t('leaderboard.page_title'), user }) %>

<div class="card survey-page-card">
  <% const driverShortCodeMap = {
    "Alexander Albon": "ALB",
    "Arvid Lindblad": "LIN",
    "Carlos Sainz Jr.": "SAI",
    "Charles Leclerc": "LEC",
    "Esteban Ocon": "OCO",
    "Fernando Alonso": "ALO",
    "Franco Colapinto": "COL",
    "Gabriel Bortoleto": "BOR",
    "George Russell": "RUS",
    "Isack Hadjar": "HAD",
    "Kimi Antonelli": "ANT",
    "Lance Stroll": "STR",
    "Lando Norris": "NOR",
    "Lewis Hamilton": "HAM",
    "Liam Lawson": "LAW",
    "Max Verstappen": "VER",
    "Nico Hulkenberg": "HUL",
    "Oliver Bearman": "BEA",
    "Oscar Piastri": "PIA",
    "Pierre Gasly": "GAS",
    "Sergio Perez": "PER",
    "Valtteri Bottas": "BOT"
  }; %>
  <% const teamShortCodeMap = {
    "Alpine": "ALP",
    "Aston Martin": "AST",
    "Audi": "AUD",
    "Cadillac": "CAD",
    "Ferrari": "FER",
    "Haas F1 Team": "HAA",
    "McLaren": "MCL",
    "Mercedes": "MER",
    "Racing Bulls": "RBT",
    "Red Bull Racing": "RBR",
    "Williams": "WIL"
  }; %>
  <% const raceShortCodeMap = {
    "Australian Grand Prix": "AUS",
    "Chinese Grand Prix": "CHN",
    "Japanese Grand Prix": "JPN",
    "Bahrain Grand Prix": "BHR",
    "Saudi Arabian Grand Prix": "SAU",
    "Miami Grand Prix": "MIA",
    "Canadian Grand Prix": "CAN",
    "Monaco Grand Prix": "MON",
    "Barcelona-Catalunya Grand Prix": "CAT",
    "Austrian Grand Prix": "AUT",
    "British Grand Prix": "GBR",
    "Belgian Grand Prix": "BEL",
    "Hungarian Grand Prix": "HUN",
    "Dutch Grand Prix": "NED",
    "Italian Grand Prix": "ITA",
    "Spanish Grand Prix": "ESP",
    "Azerbaijan Grand Prix": "AZE",
    "Singapore Grand Prix": "SIN",
    "United States Grand Prix": "USA",
    "Mexico City Grand Prix": "MEX",
    "Sao Paulo Grand Prix": "BRA",
    "Las Vegas Grand Prix": "LVG",
    "Qatar Grand Prix": "QAT",
    "Abu Dhabi Grand Prix": "ABD"
  }; %>
  <% const escapeRegExp = (value) => String(value || "").replace(/[.*+?^${}()|[\]\\]/g, "\\$&"); %>
  <% const shortRaceCode = (race) => raceShortCodeMap[String(race || "").trim()] || String(race || ""); %>
  <% const abbreviateEntities = (text) => {
    let output = String(text || "");
    const entries = Object.entries({ ...teamShortCodeMap, ...driverShortCodeMap })
      .sort((a, b) => b[0].length - a[0].length);
    entries.forEach(([label, code]) => {
      output = output.replace(new RegExp(escapeRegExp(label), "g"), code);
    });
    return output;
  }; %>
  <% const shouldPreferCompactValue = (question, raw, display) => {
    if (!question || raw == null || raw === "" || !display || display === "-") return false;
    if (question.id === "select_three_races_dnfs") return true;

    const text = String(raw).trim();
    if (text.startsWith("[")) {
      try {
        const parsed = JSON.parse(text);
        return Array.isArray(parsed) && parsed.length > 1;
      } catch (err) {}
    }

    return false;
  }; %>
  <% const formatSimpleValue = (value) => {
    const text = String(value);
    if (text === 'yes') return t('questions.yes');
    if (text === 'no') return t('questions.no');
    if (text === 'tie') return t('questions.tie');
    return text;
  }; %>
  <% const formatInlineValue = (value) => {
    if (value == null || value === "") return "-";
    if (Array.isArray(value)) return value.join(" | ");
    if (typeof value === "object") {
      return Object.entries(value)
        .map(([key, inner]) => `${key}: ${formatInlineValue(inner)}`)
        .join("; ");
    }
    return formatSimpleValue(value);
  }; %>
  <% const formatValue = (question, raw) => {
    if (raw == null || raw === "") return "-";
    const text = String(raw);
    const type = question?.type || "text";
    const looksJson = text.startsWith("[") || text.startsWith("{");
    if (
      type === "ranking" ||
      type === "multi_select" ||
      type === "multi_select_limited" ||
      type === "teammate_battle" ||
      type === "boolean_with_optional_driver" ||
      type === "numeric_with_driver" ||
      type === "single_choice_with_driver" ||
      looksJson
    ) {
      try {
        const parsed = JSON.parse(text);
        if (question?.id === "select_three_races_dnfs") {
          if (Array.isArray(parsed)) {
            return parsed.map(shortRaceCode).join(" | ") || "-";
          }
          const dnfByRace = parsed?.dnf_by_race;
          if (dnfByRace && typeof dnfByRace === "object") {
            const parts = Object.entries(dnfByRace)
              .filter(([, count]) => Number(count) > 0)
              .map(([race, count]) => `${shortRaceCode(race)}: ${count}`);
            return parts.join(" | ") || "-";
          }
        }
        if (Array.isArray(parsed)) return parsed.join(" | ");
        if (parsed && typeof parsed === "object") {
          if (type === "teammate_battle") {
            if (parsed.winner === "tie") return t('questions.tie');
            if (parsed.winner) {
              const diffText =
                parsed.diff == null || parsed.diff === ""
                  ? ""
                  : ` (${parsed.diff})`;
              return `${parsed.winner}${diffText}`;
            }
          }
          if (type === "boolean_with_optional_driver") {
            const choice = parsed.choice == null ? "-" : formatSimpleValue(parsed.choice);
            return parsed.driver ? `${choice} - ${parsed.driver}` : choice;
          }
          if (type === "numeric_with_driver" || type === "single_choice_with_driver") {
            const value = parsed.value == null ? "-" : String(parsed.value);
            return parsed.driver ? `${value} - ${parsed.driver}` : value;
          }
          return formatInlineValue(parsed);
        }
        return parsed == null ? "-" : formatSimpleValue(parsed);
      } catch (err) {
        return formatSimpleValue(text);
      }
    }
    return formatSimpleValue(text);
  }; %>
  <% const leaderboardBaseHref =
    typeof leaderboardBasePath === "string" && leaderboardBasePath
      ? leaderboardBasePath
      : groupPath(group, "/leaderboard"); %>
  <% const currentGroupPath =
    typeof groupBasePath === "string" && groupBasePath
      ? groupBasePath
      : (leaderboardBaseHref.endsWith("/leaderboard")
          ? leaderboardBaseHref.replace(/\/leaderboard$/, "")
          : groupPath(group)); %>
  <% const leaderboardQueryPart =
    typeof leaderboardQuery === "string" && leaderboardQuery.trim()
      ? leaderboardQuery.trim()
      : ""; %>
  <% const leaderboardExtraParams = {}; %>
  <% if (leaderboardQueryPart) { %>
    <% for (const [key, value] of new URLSearchParams(leaderboardQueryPart).entries()) { %>
      <% leaderboardExtraParams[key] = value; %>
    <% } %>
  <% } %>
  <% const snapshotFilterParams = {}; %>
  <% for (const [key, value] of Object.entries(leaderboardExtraParams)) { %>
    <% if (key === "page" || key === "snapshot") continue; %>
    <% snapshotFilterParams[key] = value; %>
  <% } %>
  <% const selectedSnapshotKey =
    selectedActualSnapshotId == null ? "" : String(selectedActualSnapshotId); %>
  <% const safeHistory = leaderboardHistory || { hasEnoughHistory: false, rounds: [], series: [], maxTotal: 0 }; %>
  <% const safeInsights = participantInsights || { selectedParticipant: null, comparisonRows: [], gaps: [], strengths: [], distinctive: [], emptyReason: null }; %>
  <% const safeBreakdown = selectedBreakdown || { mode: 'scored', hasScoredRows: false, rows: [] }; %>
  <% const canViewBreakdown = Boolean(canViewQuestionBreakdown); %>
  <% const selectedParticipantKey = selectedParticipantId == null ? "" : String(selectedParticipantId); %>
  <% const safeSelectedLatestRoundDelta = selectedLatestRoundDelta || null; %>
  <% const currentUserKey = user && user.id != null ? String(user.id) : ""; %>
  <% const showSnapshotReviewStatus = user && Number(user.is_admin || 0) === 1; %>
  <% const safeLatestRoundDeltaMeta = latestRoundDeltaMeta || null; %>
  <% const hasRoundDeltaColumn = Boolean(safeLatestRoundDeltaMeta); %>
  <% const leaderboardHref = (updates = {}, anchor = 'leaderboard-overview') => {
    const params = new URLSearchParams(leaderboardQueryPart);
    params.delete('page');
    Object.entries(updates).forEach(([key, value]) => {
      if (value == null || value === '') params.delete(key);
      else params.set(key, String(value));
    });
    const query = params.toString();
    return `${leaderboardBaseHref}${query ? `?${query}` : ''}${anchor ? `#${anchor}` : ''}`;
  }; %>
  <% const formatSigned = (value) => {
    const number = Number(value || 0);
    if (!Number.isFinite(number) || number === 0) return '0';
    return number > 0 ? `+${number}` : String(number);
  }; %>
  <% const formatRankDelta = (value) => {
    const number = Number(value || 0);
    if (!Number.isFinite(number) || number === 0) return '0';
    return number > 0 ? `+${number}` : String(number);
  }; %>
  <% const rankDeltaAbs = (value) => {
    const number = Number(value || 0);
    if (!Number.isFinite(number) || number === 0) return '';
    return String(Math.abs(number));
  }; %>
  <% const formatRankDeltaLabel = (value) => {
    const number = Number(value || 0);
    if (!Number.isFinite(number) || number === 0) return t('leaderboard.rank_delta_steady');
    return number > 0
      ? t('leaderboard.rank_delta_up', { count: number })
      : t('leaderboard.rank_delta_down', { count: Math.abs(number) });
  }; %>
  <% const formatInsightAbsPoints = (value) => {
    const number = Math.abs(Number(value || 0));
    if (!Number.isFinite(number)) return `0 ${t('leaderboard.points_short')}`;
    return `${Number.isInteger(number) ? number : Number(number.toFixed(2))} ${t('leaderboard.points_short')}`;
  }; %>
  <% const formatInsightSignedPoints = (value) => {
    const number = Number(value || 0);
    if (!Number.isFinite(number) || number === 0) return `0 ${t('leaderboard.points_short')}`;
    return number > 0 ? `+${formatInsightAbsPoints(number)}` : `-${formatInsightAbsPoints(number)}`;
  }; %>
  <% const formatInsightCountLabel = (count) => {
    const number = Number(count || 0);
    return t(number === 1 ? 'leaderboard.question_count_one' : 'leaderboard.question_count_many', {
      count: number
    });
  }; %>
  <% const sumInsightField = (items, field) => {
    const total = (items || []).reduce((sum, item) => sum + Number(item?.[field] || 0), 0);
    return Number(total.toFixed(2));
  }; %>
  <% const selectedInsightName = safeInsights.selectedParticipant?.name || t('leaderboard.this_participant'); %>
  <% const summarizeInsightRows = (type, items) => {
    const rows = items || [];
    const count = rows.length;
    const first = rows[0];
    if (!count || !first) return '';
    if (type === 'gaps') {
      const total = sumInsightField(rows, 'difference');
      if (count === 1) {
        return t('leaderboard.gaps_summary_one', {
          question: first.questionNumber,
          name: selectedInsightName,
          points: formatInsightAbsPoints(total)
        });
      }
      return t('leaderboard.gaps_summary_many', {
        count_label: formatInsightCountLabel(count),
        name: selectedInsightName,
        points: formatInsightAbsPoints(total)
      });
    }
    if (type === 'strengths') {
      const total = sumInsightField(rows, 'difference');
      if (count === 1) {
        return t('leaderboard.strengths_summary_one', {
          question: first.questionNumber,
          name: selectedInsightName,
          points: formatInsightSignedPoints(total)
        });
      }
      return t('leaderboard.strengths_summary_many', {
        count_label: formatInsightCountLabel(count),
        name: selectedInsightName,
        points: formatInsightSignedPoints(total)
      });
    }
    if (type === 'distinctive') {
      const total = sumInsightField(rows, 'selectedPoints');
      if (count === 1) {
        return t('leaderboard.distinctive_summary_one', {
          question: first.questionNumber,
          name: selectedInsightName,
          points: formatInsightAbsPoints(total)
        });
      }
      return t('leaderboard.distinctive_summary_many', {
        count_label: formatInsightCountLabel(count),
        name: selectedInsightName,
        points: formatInsightAbsPoints(total)
      });
    }
    return '';
  }; %>
  <% const truncatePrompt = (value) => {
    const text = String(value || '');
    return text.length > 90 ? `${text.slice(0, 87)}...` : text;
  }; %>
  <% const chartPalette = [
    '#455a64',
    '#1f7a8c',
    '#6c5ce7',
    '#2b6f3e',
    '#8a6d3b',
    '#3867d6',
    '#ad1457',
    '#00766c',
    '#725ac1',
    '#c44d00',
    '#5f6f52',
    '#7b4f86'
  ]; %>
  <% const niceChartStep = (value) => {
    const raw = Math.abs(Number(value || 0));
    if (!Number.isFinite(raw) || raw <= 0) return 1;
    const power = 10 ** Math.floor(Math.log10(raw));
    const normalized = raw / power;
    const multiplier = normalized <= 1 ? 1 : (normalized <= 2 ? 2 : (normalized <= 5 ? 5 : 10));
    return multiplier * power;
  }; %>
  <% const formatChartTick = (value) => {
    const number = Number(value || 0);
    if (!Number.isFinite(number)) return '0';
    if (Number.isInteger(number)) return String(number);
    return String(Number(number.toFixed(1)));
  }; %>

  <div class="page-title-row">
    <h1><%= group.name %>: <%= t('leaderboard.page_title') %></h1>
    <a class="link page-back-link" href="<%= currentGroupPath %>">&lt; <%= t('group.back_to_group') %></a>
  </div>

  <% if (Object.keys(actuals || {}).length === 0) { %>
    <div class="alert"><%= t('leaderboard.no_actuals') %></div>
  <% } %>

  <% if (leaderboard.length === 0) { %>
    <div class="alert"><%= t('leaderboard.no_scored_responses') %></div>
  <% } else { %>
    <div id="leaderboard-overview" class="leaderboard-layout">
      <div class="leaderboard-overview-row">
        <div class="leaderboard-main-column">
        <% if ((actualSnapshots || []).length > 0) { %>
          <form method="get" action="<%= leaderboardBaseHref %>" class="leaderboard-snapshot-form inline-actions">
            <% Object.entries(snapshotFilterParams).forEach(([key, value]) => { %>
              <input type="hidden" name="<%= key %>" value="<%= value %>" />
            <% }) %>
            <select
              id="snapshot-select"
              name="snapshot"
              aria-label="<%= t('leaderboard.snapshot_label') %>"
              onchange="this.form.submit()"
            >
              <% actualSnapshots.forEach((snapshot) => { %>
                <option value="<%= snapshot.id %>" <%= selectedSnapshotKey === String(snapshot.id) ? "selected" : "" %>>
                  <%= snapshot.label %><%= showSnapshotReviewStatus && snapshot.reviewStatus === 'pending' ? ` | ${t('leaderboard.pending_review')}` : '' %>
                </option>
              <% }) %>
            </select>
            <noscript><button type="submit" class="secondary"><%= t('leaderboard.apply_snapshot') %></button></noscript>
          </form>
        <% } %>

        <section class="leaderboard-main-card">
          <table class="table">
            <thead>
              <tr>
                <th class="leaderboard-position-header" aria-label="<%= t('leaderboard.position') %>"><span aria-hidden="true">POS</span></th>
                <th class="leaderboard-name-header"><%= t('common.name').toUpperCase() %></th>
                <th class="leaderboard-points-header" aria-label="<%= t('leaderboard.points_label') %>"><span aria-hidden="true">PTS</span></th>
              </tr>
            </thead>
            <tbody>
              <% leaderboard.forEach((row, index) => { %>
                <% const rowDelta = hasRoundDeltaColumn ? row.latestRoundDelta : null; %>
                <% const rowRankDelta = rowDelta ? Number(rowDelta.rankDelta || 0) : null; %>
                <% const rowDeltaClass = rowRankDelta > 0 ? 'is-positive' : (rowRankDelta < 0 ? 'is-negative' : 'is-empty'); %>
                <% const rowDeltaDirection = rowRankDelta == null ? 'none' : (rowRankDelta > 0 ? 'up' : (rowRankDelta < 0 ? 'down' : 'steady')); %>
                <% const rowDeltaLabel = rowRankDelta == null
                  ? t('leaderboard.no_movement_data')
                  : (rowRankDelta === 0 ? t('leaderboard.no_rank_change') : `${t('leaderboard.rank_change_aria')}: ${rowRankDelta > 0 ? '+' : ''}${rowRankDelta}`); %>
                <tr
                  class="leaderboard-rank-row <%= String(row.userId) === selectedParticipantKey ? 'is-active' : '' %>"
                  data-leaderboard-row-participant="<%= row.userId %>"
                  data-leaderboard-row-href="<%= leaderboardHref({ participant: row.userId }) %>"
                >
                  <td class="leaderboard-position-cell">
                    <span class="leaderboard-position-wrap">
                      <span class="leaderboard-position-number"><%= row.rank %></span>
                      <% if (hasRoundDeltaColumn) { %>
                        <span class="leaderboard-position-delta <%= rowDeltaClass %>" data-rank-delta-direction="<%= rowDeltaDirection %>" aria-label="<%= rowDeltaLabel %>">
                          <% if (rowRankDelta && Number.isFinite(rowRankDelta)) { %>
                            <svg class="leaderboard-delta-icon" viewBox="0 0 10 10" aria-hidden="true" focusable="false">
                              <path d="<%= rowRankDelta > 0 ? 'M2 6.4 5 3.4l3 3' : 'M2 3.6 5 6.6l3-3' %>"></path>
                            </svg>
                            <span class="leaderboard-delta-value"><%= rankDeltaAbs(rowRankDelta) %></span>
                          <% } else { %>
                            <span class="leaderboard-delta-steady">-</span>
                          <% } %>
                        </span>
                      <% } %>
                    </span>
                  </td>
                  <td>
                    <a
                      class="leaderboard-row-link"
                      href="<%= leaderboardHref({ participant: row.userId }) %>"
                      title="<%= row.name %>"
                      data-leaderboard-participant-link
                    >
                      <strong class="leaderboard-row-name"><%= row.name %></strong>
                    </a>
                  </td>
                  <td><strong><%= row.total %></strong></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
          <% if (totalLeaderboardPages > 1) { %>
            <%- include('partials/admin_pagination', {
              currentPage: currentLeaderboardPage,
              totalPages: totalLeaderboardPages,
              pageParamName: 'page',
              basePath: leaderboardBaseHref,
              extraParams: leaderboardExtraParams,
              anchorId: 'leaderboard-overview',
              label: t('leaderboard.page_title'),
              perPage: leaderboardPerPage,
              showSummary: false,
              showBoundaryControls: false
            }) %>
          <% } %>
          </section>
        </div>

        <aside class="leaderboard-trend-panel" aria-label="<%= t('leaderboard.chart_aria_label') %>">
          <% if (safeHistory.hasEnoughHistory && safeHistory.series.length > 0) { %>
            <% const chartWidth = 960; %>
            <% const chartHeight = 360; %>
            <% const padLeft = 52; %>
            <% const padRight = 24; %>
            <% const padTop = 16; %>
            <% const padBottom = 42; %>
            <% const plotWidth = chartWidth - padLeft - padRight; %>
            <% const plotHeight = chartHeight - padTop - padBottom; %>
            <% const chartLatestPoints = safeHistory.series
              .map((series) => series.points?.[series.points.length - 1])
              .filter(Boolean); %>
            <% const chartTopRankTotals = chartLatestPoints
              .filter((point) => Number(point.rank || 0) > 0 && Number(point.rank || 0) <= 10)
              .map((point) => Number(point.total))
              .filter((value) => Number.isFinite(value)); %>
            <% const chartAllLatestTotals = chartLatestPoints
              .map((point) => Number(point.total))
              .filter((value) => Number.isFinite(value)); %>
            <% const chartDomainTotals = chartTopRankTotals.length > 0 ? chartTopRankTotals : chartAllLatestTotals; %>
            <% const chartCurrentMin = chartDomainTotals.length > 0 ? Math.min(...chartDomainTotals) : 0; %>
            <% const chartCurrentMax = chartDomainTotals.length > 0
              ? Math.max(...chartDomainTotals)
              : Math.max(1, Number(safeHistory.maxTotal || 0)); %>
            <% const chartStep = niceChartStep(
              chartCurrentMax > chartCurrentMin
                ? (chartCurrentMax - chartCurrentMin) / 4
                : Math.max(1, chartCurrentMax / 4)
            ); %>
            <% const chartDomainMin = chartCurrentMin > 0
              ? Math.max(0, Math.floor(chartCurrentMin / chartStep) * chartStep)
              : 0; %>
            <% const chartDomainMax = Math.max(
              chartDomainMin + chartStep,
              Math.ceil(Math.max(chartCurrentMax, chartDomainMin + chartStep) / chartStep) * chartStep
            ); %>
            <% const chartDomainSpan = Math.max(1, chartDomainMax - chartDomainMin); %>
            <% const chartTickValues = [
              chartDomainMin,
              chartDomainMin + chartDomainSpan / 2,
              chartDomainMax
            ]; %>
            <% const xForIndex = (idx) => safeHistory.rounds.length <= 1
              ? padLeft
              : padLeft + (idx / (safeHistory.rounds.length - 1)) * plotWidth; %>
            <% const selectedRoundIndex = safeHistory.rounds.findIndex((round) => String(round.id) === selectedSnapshotKey); %>
            <% const yForTotal = (total) => {
              const value = Number(total || 0);
              const clamped = Math.min(chartDomainMax, Math.max(chartDomainMin, Number.isFinite(value) ? value : chartDomainMin));
              return padTop + plotHeight - ((clamped - chartDomainMin) / chartDomainSpan) * plotHeight;
            }; %>
            <div class="leaderboard-chart-content">
            <div class="leaderboard-chart-wrap">
              <svg
                class="leaderboard-trend-chart"
                viewBox="0 0 <%= chartWidth %> <%= chartHeight %>"
                role="img"
                aria-label="<%= t('leaderboard.chart_aria_label') %>"
                data-chart-domain-min="<%= formatChartTick(chartDomainMin) %>"
                data-chart-domain-max="<%= formatChartTick(chartDomainMax) %>"
                data-chart-selected-round-id="<%= selectedSnapshotKey %>"
              >
                <line x1="<%= padLeft %>" y1="<%= padTop %>" x2="<%= padLeft %>" y2="<%= padTop + plotHeight %>" class="leaderboard-chart-axis" />
                <line x1="<%= padLeft %>" y1="<%= padTop + plotHeight %>" x2="<%= padLeft + plotWidth %>" y2="<%= padTop + plotHeight %>" class="leaderboard-chart-axis" />
                <% if (selectedRoundIndex >= 0) { %>
                  <% const selectedRoundX = xForIndex(selectedRoundIndex); %>
                  <line
                    x1="<%= selectedRoundX %>"
                    y1="<%= padTop %>"
                    x2="<%= selectedRoundX %>"
                    y2="<%= padTop + plotHeight %>"
                    class="leaderboard-chart-selected-round-marker"
                    data-chart-selected-round-marker
                    aria-hidden="true"
                  />
                <% } %>
                <% chartTickValues.forEach((tickValue) => { %>
                  <% const y = yForTotal(tickValue); %>
                  <line x1="<%= padLeft %>" y1="<%= y %>" x2="<%= padLeft + plotWidth %>" y2="<%= y %>" class="leaderboard-chart-grid" />
                  <text x="<%= padLeft - 10 %>" y="<%= y + 4 %>" text-anchor="end" class="leaderboard-chart-label"><%= formatChartTick(tickValue) %></text>
                <% }) %>
                <% safeHistory.rounds.forEach((round, idx) => { %>
                  <% const x = xForIndex(idx); %>
                  <text x="<%= x %>" y="<%= chartHeight - 14 %>" text-anchor="middle" class="leaderboard-chart-label">R<%= round.roundNumber %></text>
                <% }) %>
                <% safeHistory.series.forEach((series, seriesIndex) => { %>
                  <% const isSelected = String(series.participantId) === selectedParticipantKey; %>
                  <% const isCurrentUser = currentUserKey && String(series.participantId) === currentUserKey; %>
                  <% const cssClass = `leaderboard-chart-line ${isSelected ? 'is-selected' : ''} ${isCurrentUser ? 'is-current-user' : ''}`; %>
                  <% const pointsAttr = series.points.map((point, idx) => `${xForIndex(idx).toFixed(2)},${yForTotal(point.total).toFixed(2)}`).join(' '); %>
                  <% const seriesColor = chartPalette[seriesIndex % chartPalette.length]; %>
                <g class="leaderboard-chart-series <%= isSelected ? 'is-selected' : '' %> <%= isCurrentUser ? 'is-current-user' : '' %>" data-chart-series="<%= series.participantId %>">
                  <polyline class="<%= cssClass %>" points="<%= pointsAttr %>" style="--series-index:<%= seriesIndex %>; --chart-line-color:<%= seriesColor %>;" />
                    <% series.points.forEach((point, idx) => { %>
                      <% const x = xForIndex(idx); %>
                      <% const y = yForTotal(point.total); %>
                      <circle class="<%= cssClass %>" cx="<%= x %>" cy="<%= y %>" r="<%= isSelected || isCurrentUser ? 4 : 2.8 %>" style="--series-index:<%= seriesIndex %>; --chart-line-color:<%= seriesColor %>;">
                        <title><%= t('leaderboard.chart_point_title', { name: series.name, points: point.total, round: point.roundNumber, rank: point.rank ? t('leaderboard.chart_rank_suffix', { rank: point.rank }) : '' }) %></title>
                      </circle>
                    <% }) %>
                </g>
              <% }) %>
            </svg>
          </div>
          <div class="leaderboard-chart-legend" aria-label="<%= t('leaderboard.plotted_participants') %>">
            <% safeHistory.series.forEach((series, seriesIndex) => { %>
              <% const isSelected = String(series.participantId) === selectedParticipantKey; %>
              <% const isCurrentUser = currentUserKey && String(series.participantId) === currentUserKey; %>
                <div
                  class="leaderboard-chart-legend-item <%= isSelected ? 'is-selected' : '' %> <%= isCurrentUser ? 'is-current-user' : '' %>"
                  data-chart-legend-item="<%= series.participantId %>"
                  style="--series-index:<%= seriesIndex %>; --chart-line-color:<%= chartPalette[seriesIndex % chartPalette.length] %>;"
                >
                  <input
                    class="leaderboard-chart-toggle"
                    type="checkbox"
                    checked
                    aria-label="<%= series.name %>"
                    data-chart-series-toggle="<%= series.participantId %>"
                  />
                  <a
                    class="leaderboard-chart-legend-link"
                    href="<%= leaderboardHref({ participant: series.participantId }) %>"
                    title="<%= series.name %>"
                    data-leaderboard-participant-link
                  >
                    <span class="leaderboard-legend-swatch"></span>
                    <span class="leaderboard-legend-name"><%= series.name %></span>
                  </a>
                </div>
            <% }) %>
          </div>
          </div>
          <% } else { %>
            <p class="muted leaderboard-empty-copy"><%= t('leaderboard.trends_empty') %></p>
          <% } %>
        </aside>
      </div>

      <section class="leaderboard-detail-card leaderboard-selected-panel">
          <% if (safeInsights.selectedParticipant) { %>
            <div class="leaderboard-member-heading">
              <div>
                <h2 id="leaderboard-selected-heading"><%= safeInsights.selectedParticipant.name %></h2>
                <p class="muted leaderboard-member-meta">
                  <%= t('leaderboard.rank_label') %> <strong><%= safeInsights.selectedParticipant.rank %></strong>
                  <span aria-hidden="true">-</span>
                  <strong><%= safeInsights.selectedParticipant.total %></strong> <%= t('leaderboard.points_word') %>
                  <% if (safeSelectedLatestRoundDelta) { %>
                    <span aria-hidden="true">-</span>
                    <%= t('leaderboard.race_change') %> <strong><%= formatSigned(safeSelectedLatestRoundDelta.pointsDelta) %> <%= t('leaderboard.points_short') %></strong>
                    <span aria-hidden="true">-</span>
                    <strong><%= formatRankDeltaLabel(safeSelectedLatestRoundDelta.rankDelta) %></strong>
                  <% } %>
                </p>
              </div>
            </div>

            <div class="leaderboard-insight-grid">
              <section>
                <h3><%= t('leaderboard.gaps_above') %></h3>
                <% if (safeInsights.gaps.length > 0) { %>
                  <p class="muted leaderboard-insight-summary">
                    <%= summarizeInsightRows('gaps', safeInsights.gaps) %>
                  </p>
                  <ul class="leaderboard-insight-list">
                    <% safeInsights.gaps.forEach((item) => { %>
                      <li>
                        <span class="leaderboard-question-chip leaderboard-insight-question-chip" tabindex="0" aria-label="Q<%= item.questionNumber %>: <%= item.prompt %>">
                          <span class="leaderboard-question-code">Q<%= item.questionNumber %></span>
                          <span class="leaderboard-question-tooltip"><%= item.prompt %></span>
                        </span>
                        <strong><%= formatSigned(-item.difference) %> <%= t('leaderboard.points_short') %></strong>
                      </li>
                    <% }) %>
                  </ul>
                <% } else { %>
                  <p class="muted"><%= t('leaderboard.gaps_empty') %></p>
                <% } %>
              </section>

              <section>
                <h3><%= t('leaderboard.strengths') %></h3>
                <% if (safeInsights.strengths.length > 0) { %>
                  <p class="muted leaderboard-insight-summary">
                    <%= summarizeInsightRows('strengths', safeInsights.strengths) %>
                  </p>
                  <ul class="leaderboard-insight-list">
                    <% safeInsights.strengths.forEach((item) => { %>
                      <li>
                        <span class="leaderboard-question-chip leaderboard-insight-question-chip" tabindex="0" aria-label="Q<%= item.questionNumber %>: <%= item.prompt %>">
                          <span class="leaderboard-question-code">Q<%= item.questionNumber %></span>
                          <span class="leaderboard-question-tooltip"><%= item.prompt %></span>
                        </span>
                        <strong><%= formatSigned(item.difference) %> <%= t('leaderboard.points_short') %></strong>
                      </li>
                    <% }) %>
                  </ul>
                <% } else { %>
                  <p class="muted"><%= t('leaderboard.strengths_empty') %></p>
                <% } %>
              </section>

              <section class="leaderboard-insight-wide">
                <h3><%= t('leaderboard.distinctive_picks') %></h3>
                <% if (safeInsights.distinctive.length > 0) { %>
                  <p class="muted leaderboard-insight-summary">
                    <%= summarizeInsightRows('distinctive', safeInsights.distinctive) %>
                  </p>
                  <ul class="leaderboard-insight-list">
                    <% safeInsights.distinctive.forEach((item) => { %>
                      <li>
                        <span class="leaderboard-question-chip leaderboard-insight-question-chip" tabindex="0" aria-label="Q<%= item.questionNumber %>: <%= item.prompt %>">
                          <span class="leaderboard-question-code">Q<%= item.questionNumber %></span>
                          <span class="leaderboard-question-tooltip"><%= item.prompt %></span>
                        </span>
                        <strong><%= item.selectedPoints %> <%= t('leaderboard.points_short') %></strong>
                      </li>
                    <% }) %>
                  </ul>
                <% } else { %>
                  <p class="muted"><%= t('leaderboard.distinctive_empty') %></p>
                <% } %>
              </section>
            </div>

            <% if (canViewBreakdown) { %>
              <div class="leaderboard-breakdown-header">
                <div>
                  <h3><%= t('leaderboard.question_breakdown') %></h3>
                  <p class="muted"><%= safeBreakdown.mode === 'all' ? t('leaderboard.all_questions') : t('leaderboard.scored_questions') %></p>
                </div>
                <div class="leaderboard-breakdown-toggle" aria-label="<%= t('leaderboard.question_breakdown_filter') %>">
                  <a class="<%= safeBreakdown.mode === 'scored' ? 'is-active' : '' %>" href="<%= leaderboardHref({ breakdown: '' }, 'leaderboard-breakdown') %>"><%= t('leaderboard.scored') %></a>
                  <a class="<%= safeBreakdown.mode === 'all' ? 'is-active' : '' %>" href="<%= leaderboardHref({ breakdown: 'all' }, 'leaderboard-breakdown') %>"><%= t('leaderboard.all') %></a>
                </div>
              </div>

              <div id="leaderboard-breakdown">
                <% if (safeBreakdown.rows.length > 0) { %>
                  <table class="table compact leaderboard-breakdown-table">
                    <thead>
                      <tr>
                        <th><%= t('leaderboard.question_short') %></th>
                        <th><%= t('leaderboard.prediction') %></th>
                        <th><%= t('leaderboard.actual') %></th>
                        <th><%= t('leaderboard.points_short_caps') %></th>
                      </tr>
                    </thead>
                    <tbody>
                    <% safeBreakdown.rows.forEach((breakdownRow) => { %>
                      <% const q = breakdownRow.question; %>
                      <% const actualDisplay = formatValue(q, breakdownRow.actualRaw); %>
                      <% const answerDisplay = formatValue(q, breakdownRow.predictionRaw); %>
                      <tr class="<%= breakdownRow.isScored ? '' : 'is-unscored' %>">
                        <td>
                          <span class="leaderboard-question-chip" tabindex="0">
                            <span class="leaderboard-question-code">Q<%= breakdownRow.questionNumber %></span>
                            <span class="leaderboard-question-tooltip"><%= q.prompt %></span>
                          </span>
                        </td>
                        <td>
                          <span class="leaderboard-value-cell <%= shouldPreferCompactValue(q, breakdownRow.predictionRaw, answerDisplay) ? 'has-short' : '' %>">
                            <span class="leaderboard-value-full"><%= answerDisplay %></span>
                            <span class="leaderboard-value-short"><%= abbreviateEntities(answerDisplay) %></span>
                          </span>
                        </td>
                        <td>
                          <span class="leaderboard-value-cell <%= shouldPreferCompactValue(q, breakdownRow.actualRaw, actualDisplay) ? 'has-short' : '' %>">
                            <span class="leaderboard-value-full"><%= actualDisplay %></span>
                            <span class="leaderboard-value-short"><%= abbreviateEntities(actualDisplay) %></span>
                          </span>
                        </td>
                        <td><strong><%= breakdownRow.points %></strong></td>
                      </tr>
                    <% }) %>
                    </tbody>
                  </table>
                <% } else { %>
                  <p class="muted leaderboard-empty-copy">
                    <%= safeBreakdown.mode === 'scored' ? t('leaderboard.no_scored_questions_participant') : t('leaderboard.no_question_answers_participant') %>
                  </p>
                <% } %>
              </div>
            <% } else { %>
              <div class="leaderboard-breakdown-locked">
                <h3><%= t('leaderboard.question_breakdown') %></h3>
                <p class="muted"><%= t('leaderboard.sign_in_breakdown_prompt') %></p>
                <a class="link" href="/login?redirectTo=<%= encodeURIComponent(leaderboardHref({ participant: selectedParticipantKey }, 'leaderboard-overview')) %>"><%= t('header.login') %></a>
              </div>
            <% } %>
          <% } else { %>
            <p class="muted leaderboard-empty-copy"><%= t('leaderboard.select_participant_empty') %></p>
          <% } %>
      </section>
    </div>
  <% } %>
</div>

<%- include('partials/footer') %>
