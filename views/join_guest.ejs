<%- include('partials/header', { title: t('join_guest.page_title'), user }) %>

<div class="card join-guest-card">
  <div class="join-guest-start-copy" data-join-start-copy>
    <h1><%= t('join_guest.title', { group_name: group.name }) %></h1>
    <p class="muted"><%= t('join_guest.subtitle') %></p>
  </div>

  <div class="alert join-guest-error <%= error ? '' : 'is-hidden' %>" data-join-error><%= error || '' %></div>

  <% if (currentNamedGuest && currentNamedGuest.displayName) { %>
    <div class="join-guest-current-identity">
      <p class="muted"><%= t('join_guest.current_guest_notice', { guest_name: currentNamedGuest.displayName }) %></p>
      <div class="join-guest-actions">
        <form method="post" action="/join/<%= code %>/guest/continue-current">
          <%- csrfField() %>
          <% if (requirePassword && !canShowNamedGuestPicker) { %>
            <label>
              <%= t('join_guest.group_password_label') %>
              <input type="password" name="password" autocomplete="current-password" />
            </label>
          <% } %>
          <button type="submit" class="secondary"><%= t('join_guest.continue_as_named_guest', { guest_name: currentNamedGuest.displayName }) %></button>
        </form>
        <form method="post" action="/join/<%= code %>/guest/switch">
          <%- csrfField() %>
          <button type="submit" class="secondary"><%= t('join_guest.im_someone_else') %></button>
        </form>
      </div>
    </div>
  <% } %>

  <% if (requirePassword && !canShowNamedGuestPicker) { %>
    <form method="post" action="/join/<%= code %>/access" class="join-guest-access-form">
      <%- csrfField() %>
      <label>
        <%= t('join_guest.group_password_label') %>
        <input type="password" name="password" required autocomplete="current-password" />
      </label>
      <button type="submit" class="secondary"><%= t('join_guest.show_existing_guests') %></button>
    </form>
  <% } %>

  <form
    method="post"
    action="/join/<%= code %>/guest"
    class="join-guest-form <%= activeMode === 'returning' ? 'is-hidden' : '' %>"
    data-join-mode="new"
  >
    <%- csrfField() %>
    <div class="join-guest-step" data-join-start-step>
      <label>
        <%= t('join_guest.account_name_label') %>
        <input
          type="text"
          name="guestName"
          maxlength="40"
          required
          value="<%= displayName || '' %>"
          placeholder="<%= t('join_guest.account_name_placeholder') %>"
          autocomplete="nickname"
        />
      </label>

      <% if (requirePassword && !canShowNamedGuestPicker) { %>
        <label>
          <%= t('join_guest.group_password_label') %>
          <input type="password" name="password" required autocomplete="current-password" />
        </label>
      <% } %>

      <div class="join-guest-actions" data-join-initial-actions>
        <a class="button-link join-guest-create-account" href="<%= createAccountPath %>" data-create-account-link><%= t('home.create_account') %></a>
        <button type="button" class="secondary" data-show-guest-recovery><%= t('join_guest.join_as_guest') %></button>
      </div>

      <p class="muted join-guest-mode-row">
        <a class="join-guest-mode-link" href="/join/<%= code %>?mode=returning" data-join-mode-trigger="returning"><%= t('join_guest.already_submitted') %></a>
      </p>
    </div>

    <div class="join-guest-step join-guest-recovery-step" data-join-recovery-step hidden>
      <div class="join-guest-recovery-heading">
        <h2 data-guest-recovery-title><%= displayName ? t('join_guest.recovery_step_title', { guest_name: displayName }) : t('join_guest.recovery_step_legend') %></h2>
        <p class="muted join-guest-recovery-summary" data-guest-recovery-summary>
          <%= t('join_guest.recovery_step_summary') %>
        </p>
        <div class="join-guest-device-toggle">
          <label class="join-guest-device-switch">
            <input type="hidden" name="rememberDevice" value="0" />
            <input type="checkbox" name="rememberDevice" value="1" checked data-remember-device />
            <span class="join-guest-switch-track" aria-hidden="true">
              <span class="join-guest-switch-thumb"></span>
            </span>
            <span class="join-guest-device-copy">
              <span class="join-guest-device-title"><%= t('join_guest.remember_device_label') %></span>
              <span class="join-guest-device-note" data-guest-device-note><%= t('join_guest.remember_device_note') %></span>
            </span>
          </label>
          <span
            class="join-guest-device-help"
            tabindex="0"
            aria-label="<%= t('join_guest.remember_device_help_label') %>"
            aria-describedby="join-guest-device-tooltip"
            data-remember-device-help
          >?</span>
          <span class="join-guest-device-tooltip" role="tooltip" id="join-guest-device-tooltip" data-remember-device-tooltip>
            <%= t('join_guest.remember_device_tooltip') %>
          </span>
        </div>
      </div>

      <fieldset class="join-guest-claim-secret join-guest-recovery-fields" data-guest-recovery-fields hidden>
        <legend class="sr-only"><%= t('join_guest.recovery_step_legend') %></legend>
        <p class="muted join-guest-recovery-intro"><%= t('join_guest.recovery_intro') %></p>

        <div class="join-guest-method-grid" data-recovery-method-grid>
          <label class="choice-tile choice-tile--compact">
            <input class="choice-tile-input" type="radio" name="claimSecretMode" value="pin" checked data-claim-secret-mode="pin" />
            <span class="choice-tile-body">
              <span class="choice-tile-title"><%= t('join_guest.claim_pin_option') %></span>
            </span>
          </label>
          <label class="choice-tile choice-tile--compact">
            <input class="choice-tile-input" type="radio" name="claimSecretMode" value="passphrase" data-claim-secret-mode="passphrase" />
            <span class="choice-tile-body">
              <span class="choice-tile-title"><%= t('join_guest.claim_passphrase_option') %></span>
            </span>
          </label>
        </div>

        <div class="join-guest-recovery-panel" data-claim-pin-fields>
          <label class="join-guest-field join-guest-pin-field">
            <span class="join-guest-field-label"><%= t('join_guest.claim_pin_label') %></span>
            <span class="join-guest-pin-control">
              <span class="join-guest-pin-chip" aria-hidden="true">PIN</span>
              <input
                class="join-guest-pin-input"
                type="text"
                name="claimPin"
                inputmode="numeric"
                pattern="[0-9]{4,6}"
                minlength="4"
                maxlength="6"
                required
                autocomplete="one-time-code"
                enterkeyhint="done"
                placeholder="0000"
                aria-describedby="join-guest-pin-hint"
              />
            </span>
            <span class="join-guest-field-hint" id="join-guest-pin-hint"><%= t('join_guest.claim_pin_placeholder') %></span>
          </label>
        </div>

        <div class="join-guest-recovery-panel join-guest-passphrase-fields" data-claim-passphrase-fields hidden>
          <label class="join-guest-field">
            <span class="join-guest-field-label"><%= t('join_guest.claim_prompt_label') %></span>
            <input
              type="text"
              name="claimPrompt"
              maxlength="160"
              value="<%= defaultClaimPrompt || '' %>"
              autocomplete="off"
            />
          </label>
          <label class="join-guest-field join-guest-answer-field">
            <span class="join-guest-field-label"><%= t('join_guest.claim_passphrase_answer_label') %></span>
            <input
              type="text"
              name="claimPassphraseAnswer"
              maxlength="160"
              autocomplete="off"
              placeholder="<%= t('join_guest.claim_passphrase_answer_placeholder') %>"
            />
          </label>
        </div>
        <label class="choice-tile choice-tile--quiet join-guest-skip-recovery">
          <input class="choice-tile-input" type="checkbox" name="skipRecoverySecret" value="1" data-skip-recovery-secret />
          <span class="choice-tile-body">
            <span class="choice-tile-check" aria-hidden="true"></span>
            <span class="choice-tile-title"><%= t('join_guest.skip_recovery_secret') %></span>
          </span>
        </label>
      </fieldset>

      <div class="join-guest-actions" data-join-recovery-actions>
        <button type="submit" data-submit-guest><%= t('join_guest.continue_as_guest') %></button>
        <a class="button-link join-guest-create-account secondary" href="<%= createAccountPath %>" data-create-account-link><%= t('join_guest.create_account_instead') %></a>
      </div>
    </div>
  </form>

  <form
    method="post"
    action="/join/<%= code %>/guest/return"
    class="join-guest-form <%= activeMode === 'returning' ? '' : 'is-hidden' %>"
    data-join-mode="returning"
  >
    <%- csrfField() %>
    <% if (namedGuestOptions && namedGuestOptions.length > 0) { %>
      <label>
        <%= t('join_guest.returning_guest_label') %>
        <select name="returnGuestId" required>
          <option value=""><%= t('join_guest.returning_guest_placeholder') %></option>
          <% namedGuestOptions.forEach((option) => { %>
            <option value="<%= option.guestId %>"><%= option.displayName %></option>
          <% }) %>
        </select>
      </label>
    <% } else { %>
      <label>
        <%= t('join_guest.returning_name_label') %>
        <input
          type="text"
          name="returnGuestName"
          maxlength="40"
          required
          value="<%= returnName || '' %>"
          placeholder="<%= t('join_guest.returning_name_placeholder') %>"
          autocomplete="nickname"
        />
      </label>
    <% } %>

    <% if (requirePassword && !canShowNamedGuestPicker) { %>
      <label>
        <%= t('join_guest.group_password_label') %>
        <input type="password" name="password" required autocomplete="current-password" />
      </label>
    <% } %>

    <label>
      <%= t('join_guest.claim_secret_label') %>
      <input
        type="text"
        name="claimSecret"
        required
        autocomplete="off"
        spellcheck="false"
        placeholder="<%= t('join_guest.claim_secret_placeholder') %>"
      />
    </label>

    <div class="join-guest-actions">
      <button type="submit"><%= t('join_guest.continue_as_guest') %></button>
      <a class="button-link join-guest-create-account secondary" href="<%= createAccountPath %>"><%= t('home.create_account') %></a>
    </div>

    <p class="muted join-guest-mode-row">
      <a class="join-guest-mode-link" href="/join/<%= code %>" data-join-mode-trigger="new"><%= t('join_guest.join_as_new_guest') %></a>
    </p>
  </form>

  <p class="muted join-guest-note"><%= t('join_guest.note') %></p>
</div>

<script>
  (() => {
    const newForm = document.querySelector('[data-join-mode="new"]');
    const returningForm = document.querySelector('[data-join-mode="returning"]');
    if (!newForm || !returningForm) return;
    const newNameInput = newForm.querySelector('input[name="guestName"]');
    const returningNameInput = returningForm.querySelector('input[name="returnGuestName"]');
    const newPasswordInput = newForm.querySelector('input[name="password"]');
    const returningPasswordInput = returningForm.querySelector('input[name="password"]');
    const modeLinks = document.querySelectorAll("[data-join-mode-trigger]");
    const errorBox = document.querySelector("[data-join-error]");
    const startCopy = document.querySelector("[data-join-start-copy]");
    const startStep = newForm.querySelector("[data-join-start-step]");
    const recoveryStep = newForm.querySelector("[data-join-recovery-step]");
    const recoveryTitle = newForm.querySelector("[data-guest-recovery-title]");
    const recoveryTitleTemplate = <%- JSON.stringify(t('join_guest.recovery_step_title', { guest_name: '__GUEST_NAME__' })) %>;
    const recoveryFallbackTitle = <%- JSON.stringify(t('join_guest.recovery_step_legend')) %>;
    const claimModeRadios = newForm.querySelectorAll("[data-claim-secret-mode]");
    const recoveryMethodGrid = newForm.querySelector("[data-recovery-method-grid]");
    const pinFields = newForm.querySelector("[data-claim-pin-fields]");
    const passphraseFields = newForm.querySelector("[data-claim-passphrase-fields]");
    const claimPinInput = newForm.querySelector('input[name="claimPin"]');
    const claimPassphraseInput = newForm.querySelector('input[name="claimPassphraseAnswer"]');
    const recoveryFields = newForm.querySelector("[data-guest-recovery-fields]");
    const showGuestRecoveryButton = newForm.querySelector("[data-show-guest-recovery]");
    const skipRecoveryInput = newForm.querySelector("[data-skip-recovery-secret]");
    const createAccountLinks = newForm.querySelectorAll("[data-create-account-link]");
    const createAccountBaseHref = createAccountLinks[0]?.getAttribute("href") || "";
    const fallbackError = "Something went wrong. Please try again.";

    const clearError = () => {
      if (!errorBox) return;
      errorBox.textContent = "";
      errorBox.classList.add("is-hidden");
    };

    const showError = (message) => {
      if (!errorBox) return;
      errorBox.textContent = String(message || fallbackError);
      errorBox.classList.remove("is-hidden");
    };

    const showMode = (mode) => {
      const showReturning = mode === "returning";
      newForm.classList.toggle("is-hidden", showReturning);
      returningForm.classList.toggle("is-hidden", !showReturning);
    };

    const isRecoveryStepActive = () => !!recoveryStep && !recoveryStep.hidden;

    const showNewGuestStep = (step) => {
      const showRecovery = step === "recovery";
      if (startCopy) startCopy.hidden = showRecovery;
      if (startStep) startStep.hidden = showRecovery;
      if (recoveryStep) recoveryStep.hidden = !showRecovery;
      if (recoveryFields) recoveryFields.hidden = !showRecovery;
      updateClaimSecretMode();
    };

    const updateCreateAccountLinks = () => {
      if (!createAccountBaseHref) return;
      let href = createAccountBaseHref;
      const name = String(newNameInput?.value || "").trim();
      if (name) {
        const url = new URL(createAccountBaseHref, window.location.origin);
        url.searchParams.set("name", name);
        href = `${url.pathname}${url.search}`;
      }
      createAccountLinks.forEach((link) => {
        link.setAttribute("href", href);
      });
    };

    const copyIfEmpty = (fromInput, toInput) => {
      const fromValue = String(fromInput?.value || "").trim();
      const toValue = String(toInput?.value || "").trim();
      if (fromValue && !toValue) {
        toInput.value = fromValue;
      }
    };

    const mirrorValue = (fromInput, toInput) => {
      if (!fromInput || !toInput) return;
      toInput.value = String(fromInput.value || "");
    };

    const updateClaimSecretMode = () => {
      const selectedMode = newForm.querySelector('input[name="claimSecretMode"]:checked')?.value || "pin";
      const skipRecovery = !!skipRecoveryInput?.checked;
      const recoveryActive = isRecoveryStepActive();
      const usePassphrase = selectedMode === "passphrase";
      if (recoveryMethodGrid) recoveryMethodGrid.hidden = skipRecovery;
      if (pinFields) pinFields.hidden = skipRecovery || usePassphrase;
      if (passphraseFields) passphraseFields.hidden = skipRecovery || !usePassphrase;
      if (claimPinInput) claimPinInput.required = recoveryActive && !skipRecovery && !usePassphrase;
      if (claimPassphraseInput) claimPassphraseInput.required = recoveryActive && !skipRecovery && usePassphrase;
    };

    const showRecoveryStep = () => {
      updateCreateAccountLinks();
      if (typeof newForm.reportValidity === "function" && !newForm.reportValidity()) return;
      if (newNameInput) {
        const name = String(newNameInput.value || "").trim();
        if (recoveryTitle) {
          recoveryTitle.textContent = name ? recoveryTitleTemplate.replace("__GUEST_NAME__", name) : recoveryFallbackTitle;
        }
      }
      showNewGuestStep("recovery");
      if (claimPinInput && !skipRecoveryInput?.checked) claimPinInput.focus();
    };

    claimModeRadios.forEach((input) => {
      input.addEventListener("change", updateClaimSecretMode);
    });
    if (skipRecoveryInput) {
      skipRecoveryInput.addEventListener("change", updateClaimSecretMode);
    }
    if (showGuestRecoveryButton) {
      showGuestRecoveryButton.addEventListener("click", () => {
        clearError();
        showRecoveryStep();
      });
    }
    showNewGuestStep("start");
    updateCreateAccountLinks();

    modeLinks.forEach((link) => {
      link.addEventListener("click", (event) => {
        const nextMode = String(link.getAttribute("data-join-mode-trigger") || "").trim();
        if (!nextMode) return;
        event.preventDefault();
        if (nextMode === "returning") {
          copyIfEmpty(newNameInput, returningNameInput);
          mirrorValue(newPasswordInput, returningPasswordInput);
        } else if (nextMode === "new") {
          copyIfEmpty(returningNameInput, newNameInput);
          mirrorValue(returningPasswordInput, newPasswordInput);
          showNewGuestStep("start");
        }
        clearError();
        showMode(nextMode);
      });
    });

    if (newPasswordInput && returningPasswordInput) {
      newPasswordInput.addEventListener("input", () => {
        mirrorValue(newPasswordInput, returningPasswordInput);
      });
      returningPasswordInput.addEventListener("input", () => {
        mirrorValue(returningPasswordInput, newPasswordInput);
      });
    }

    if (newNameInput && returningNameInput) {
      newNameInput.addEventListener("input", () => {
        mirrorValue(newNameInput, returningNameInput);
        updateCreateAccountLinks();
      });
      returningNameInput.addEventListener("input", () => {
        mirrorValue(returningNameInput, newNameInput);
      });
    }

    [newForm, returningForm].forEach((form) => {
      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        clearError();
        if (form === newForm && !isRecoveryStepActive()) {
          showRecoveryStep();
          return;
        }
        if (form === newForm) {
          copyIfEmpty(returningNameInput, newNameInput);
          mirrorValue(returningPasswordInput, newPasswordInput);
        } else if (form === returningForm) {
          copyIfEmpty(newNameInput, returningNameInput);
          mirrorValue(newPasswordInput, returningPasswordInput);
        }
        const submitButton = form.querySelector('button[type="submit"]');
        if (submitButton) submitButton.disabled = true;
        try {
          const payload = new URLSearchParams(new FormData(form));
          const response = await fetch(form.action, {
            method: "POST",
            body: payload,
            credentials: "same-origin",
            headers: {
              "x-join-ajax": "1",
              "accept": "application/json"
            }
          });
          const contentType = String(response.headers.get("content-type") || "");
          const data = contentType.includes("application/json") ? await response.json() : null;
          if (response.ok && data && data.redirect) {
            window.location.assign(data.redirect);
            return;
          }
          showError(data && data.error ? data.error : fallbackError);
        } catch (error) {
          showError(fallbackError);
        } finally {
          if (submitButton) submitButton.disabled = false;
        }
      });
    });
  })();
</script>

<%- include('partials/footer') %>
