<%- include('partials/header', { title: 'Admin overview', user }) %>
<%- include('partials/admin_nav', { active: 'overview' }) %>
<% const formatAdminDate = (value) => {
  if (!value) return '-';
  if (typeof formatAdminDateTime === 'function') return formatAdminDateTime(value);
  const date = new Date(value);
  return Number.isNaN(date.getTime()) ? '-' : date.toLocaleString();
}; %>

<div class="card">
  <% const overviewReturn = `/admin/overview?groupPage=${currentGroupPage}&usersPage=${currentUserPage}&namedGuestPage=${currentNamedGuestPage}&visitorPage=${currentVisitorPage}`; %>
  <% const groupsReturn = `${overviewReturn}#admin-groups`; %>
  <% const adminsReturn = `${overviewReturn}#admin-admins`; %>
  <% const usersReturn = `${overviewReturn}#admin-users`; %>
  <% const namedGuestsReturn = `${overviewReturn}#admin-named-guests`; %>
  <% const visitorsReturn = `${overviewReturn}#admin-visitors`; %>
  <% const revealedEmailsSet = new Set((revealedEmailUserIds || []).map((id) => Number(id))); %>
  <% const maskEmail = (email) => {
    const value = String(email || '');
    const atIndex = value.indexOf('@');
    if (atIndex <= 0) return '****';
    const local = value.slice(0, atIndex);
    const domain = value.slice(atIndex + 1);
    const visibleLocal = local.length > 2 ? local.slice(0, 2) : local.slice(0, 1);
    return `${visibleLocal}****@${domain}`;
  }; %>
  <h1>Admin overview</h1>
  <p class="muted">Accounts, groups, named guests, and visitor activity.</p>
  <% if (adminError) { %>
    <div class="alert"><%= adminError %></div>
  <% } %>
  <% if (adminSuccess) { %>
    <p class="muted"><%= adminSuccess %></p>
  <% } %>

  <h2 id="admin-groups">Groups</h2>
  <table class="table compact">
    <thead>
      <tr>
        <th>Group</th>
        <th>Owner</th>
        <th>Created</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% groups.forEach(row => { %>
        <tr>
          <td>
            <a
              class="link"
              href="/admin/groups/<%= row.id %>?returnTo=<%= encodeURIComponent(groupsReturn) %>"
            ><%= row.name %></a>
          </td>
          <td><%= row.owner_name %></td>
          <td><%= formatAdminDate(row.created_at) %></td>
          <td>
            <div class="table-actions">
              <a class="link" href="/groups/<%= row.id %>/leaderboard">Leaderboard</a>
              <form method="post" action="/admin/groups/<%= row.id %>/delete" onsubmit="return confirm('Delete this group and all related data?')">
                <input type="hidden" name="returnTo" value="<%= groupsReturn %>">
                <button class="secondary" type="submit">Delete group</button>
              </form>
            </div>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
  <%- include('partials/admin_pagination', {
    basePath: '/admin/overview',
    pageParamName: 'groupPage',
    currentPage: currentGroupPage,
    totalPages: totalGroupPages,
    perPage: groupsPerPage,
    label: 'Groups',
    extraParams: { usersPage: currentUserPage, namedGuestPage: currentNamedGuestPage, visitorPage: currentVisitorPage },
    anchorId: 'admin-groups'
  }) %>

  <h2 id="admin-admins" style="margin-top:24px;">Admins</h2>
  <p class="muted">
    Admins: <strong><%= Number(adminStats?.admin_count || 0) %></strong>
    | Admin responses: <strong><%= Number(adminStats?.response_count || 0) %></strong>
    | Groups touched: <strong><%= Number(adminStats?.groups_count || 0) %></strong>
    <% if (adminStats?.last_activity_at) { %>
      | Last activity: <strong><%= formatAdminDate(adminStats.last_activity_at) %></strong>
    <% } %>
  </p>
  <table class="table compact">
    <thead>
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Created</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (!admins || admins.length === 0) { %>
        <tr>
          <td colspan="4" class="muted">No admins found.</td>
        </tr>
      <% } else { %>
        <% admins.forEach(row => { %>
          <tr>
            <td>
              <a class="link" href="/admin/users/<%= row.id %>?returnTo=<%= encodeURIComponent(adminsReturn) %>"><%= row.name %></a>
            </td>
            <td>
              <% const showAdminEmail = revealedEmailsSet.has(Number(row.id)); %>
              <span><%= showAdminEmail ? row.email : maskEmail(row.email) %></span>
              <% if (!showAdminEmail) { %>
                <form id="reveal-email-admin-<%= row.id %>" method="post" action="/admin/users/<%= row.id %>/reveal-email" style="display:inline;">
                  <input type="hidden" name="returnTo" value="<%= adminsReturn %>">
                  <input type="hidden" name="adminPassword" value="">
                  <button class="link link-button" type="button" onclick="promptEmailReveal('reveal-email-admin-<%= row.id %>')">View</button>
                </form>
              <% } %>
            </td>
            <td><%= formatAdminDate(row.created_at) %></td>
            <td>
              <div class="table-actions">
                <form method="post" action="/admin/users/<%= row.id %>/remove-admin">
                  <input type="hidden" name="returnTo" value="<%= adminsReturn %>">
                  <button class="secondary admin-toggle-btn" type="submit">Remove admin</button>
                </form>
                <form method="post" action="/admin/users/<%= row.id %>/delete" onsubmit="return confirm('Delete this user and all their memberships/responses?')">
                  <input type="hidden" name="returnTo" value="<%= adminsReturn %>">
                  <button class="secondary" type="submit">Delete user</button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      <% } %>
    </tbody>
  </table>

  <h2 id="admin-users" style="margin-top:24px;">Users</h2>
  <p class="muted">
    Users: <strong><%= Number(userStats?.user_count || 0) %></strong>
    | User responses: <strong><%= Number(userStats?.response_count || 0) %></strong>
    | Groups touched: <strong><%= Number(userStats?.groups_count || 0) %></strong>
    <% if (userStats?.last_activity_at) { %>
      | Last activity: <strong><%= formatAdminDate(userStats.last_activity_at) %></strong>
    <% } %>
  </p>
  <table class="table compact">
    <thead>
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Created</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% users.forEach(row => { %>
        <tr>
            <td>
              <a class="link" href="/admin/users/<%= row.id %>?returnTo=<%= encodeURIComponent(usersReturn) %>"><%= row.name %></a>
            </td>
            <td>
              <% const showUserEmail = revealedEmailsSet.has(Number(row.id)); %>
              <span><%= showUserEmail ? row.email : maskEmail(row.email) %></span>
              <% if (!showUserEmail) { %>
                <form id="reveal-email-user-<%= row.id %>" method="post" action="/admin/users/<%= row.id %>/reveal-email" style="display:inline;">
                  <input type="hidden" name="returnTo" value="<%= usersReturn %>">
                  <input type="hidden" name="adminPassword" value="">
                  <button class="link link-button" type="button" onclick="promptEmailReveal('reveal-email-user-<%= row.id %>')">View</button>
                </form>
              <% } %>
            </td>
            <td><%= formatAdminDate(row.created_at) %></td>
            <td>
              <div class="table-actions">
                <form method="post" action="/admin/users/<%= row.id %>/make-admin">
                  <input type="hidden" name="returnTo" value="<%= usersReturn %>">
                  <button class="secondary admin-toggle-btn" type="submit">Make admin</button>
                </form>
                <form method="post" action="/admin/users/<%= row.id %>/delete" onsubmit="return confirm('Delete this user and all their memberships/responses?')">
                  <input type="hidden" name="returnTo" value="<%= usersReturn %>">
                  <button class="secondary" type="submit">Delete user</button>
                </form>
            </div>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
  <%- include('partials/admin_pagination', {
    basePath: '/admin/overview',
    pageParamName: 'usersPage',
    currentPage: currentUserPage,
    totalPages: totalUserPages,
    perPage: usersPerPage,
    label: 'Users',
    extraParams: { groupPage: currentGroupPage, namedGuestPage: currentNamedGuestPage, visitorPage: currentVisitorPage },
    anchorId: 'admin-users'
  }) %>

  <h2 id="admin-named-guests" style="margin-top:24px;">Named guests</h2>
  <p class="muted">
    Active named guests: <strong><%= Number(namedGuestStats?.guest_count || 0) %></strong>
    | Named guest responses: <strong><%= Number(namedGuestStats?.response_count || 0) %></strong>
    | Groups touched: <strong><%= Number(namedGuestStats?.group_count || 0) %></strong>
    <% if (namedGuestStats?.last_activity_at) { %>
      | Last activity: <strong><%= formatAdminDate(namedGuestStats.last_activity_at) %></strong>
    <% } %>
  </p>
  <table class="table compact">
    <thead>
      <tr>
        <th>Name</th>
        <th>Guest ID</th>
        <th>Answers</th>
        <th>Questions</th>
        <th>Groups</th>
        <th>Latest group</th>
        <th>First seen</th>
        <th>Last seen</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (!namedGuestProfiles || namedGuestProfiles.length === 0) { %>
        <tr>
          <td colspan="9" class="muted">No named guest data yet.</td>
        </tr>
      <% } else { %>
        <% namedGuestProfiles.forEach(row => { %>
          <% const guestId = String(row.guest_id || ''); %>
          <% const shortGuestId = guestId.length > 14 ? `${guestId.slice(0, 6)}...${guestId.slice(-4)}` : guestId; %>
          <tr>
            <td>
              <a class="link" href="/admin/guests/<%= encodeURIComponent(guestId) %>?returnTo=<%= encodeURIComponent(namedGuestsReturn) %>">
                <%= row.display_name || 'Unnamed' %>
              </a>
            </td>
            <td>
              <a class="link" href="/admin/guests/<%= encodeURIComponent(guestId) %>?returnTo=<%= encodeURIComponent(namedGuestsReturn) %>">
                <code title="<%= guestId %>"><%= shortGuestId %></code>
              </a>
            </td>
            <td><%= Number(row.answers_count || 0) %></td>
            <td><%= Number(row.questions_count || 0) %></td>
            <td><%= Number(row.groups_count || 0) %></td>
            <td><%= row.latest_group_name || '-' %></td>
            <td><%= formatAdminDate(row.first_seen_at) %></td>
            <td><%= formatAdminDate(row.last_seen_at) %></td>
            <td>
              <form method="post" action="/admin/guests/<%= encodeURIComponent(guestId) %>/delete" onsubmit="return confirm('Delete this guest and all related responses?')">
                <input type="hidden" name="returnTo" value="<%= namedGuestsReturn %>">
                <button class="secondary" type="submit">Delete guest</button>
              </form>
            </td>
          </tr>
        <% }) %>
      <% } %>
    </tbody>
  </table>
  <%- include('partials/admin_pagination', {
    basePath: '/admin/overview',
    pageParamName: 'namedGuestPage',
    currentPage: currentNamedGuestPage,
    totalPages: totalNamedGuestPages,
    perPage: namedGuestProfilesPerPage,
    label: 'Named guests',
    extraParams: { groupPage: currentGroupPage, usersPage: currentUserPage, visitorPage: currentVisitorPage },
    anchorId: 'admin-named-guests'
  }) %>

  <h2 id="admin-visitors" style="margin-top:24px;">Visitors</h2>
  <p class="muted">
    Active visitors: <strong><%= Number(visitorStats?.guest_count || 0) %></strong>
    | Visitor responses: <strong><%= Number(visitorStats?.response_count || 0) %></strong>
    | Groups touched: <strong><%= Number(visitorStats?.group_count || 0) %></strong>
    <% if (visitorStats?.last_activity_at) { %>
      | Last activity: <strong><%= formatAdminDate(visitorStats.last_activity_at) %></strong>
    <% } %>
  </p>
  <table class="table compact">
    <thead>
      <tr>
        <th>Guest ID</th>
        <th>Answers</th>
        <th>Questions</th>
        <th>Groups</th>
        <th>Latest group</th>
        <th>First seen</th>
        <th>Last seen</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (!visitorProfiles || visitorProfiles.length === 0) { %>
        <tr>
          <td colspan="8" class="muted">No visitor data yet.</td>
        </tr>
      <% } else { %>
        <% visitorProfiles.forEach(row => { %>
          <% const guestId = String(row.guest_id || ''); %>
          <% const shortGuestId = guestId.length > 14 ? `${guestId.slice(0, 6)}...${guestId.slice(-4)}` : guestId; %>
          <tr>
            <td>
              <a class="link" href="/admin/guests/<%= encodeURIComponent(guestId) %>?returnTo=<%= encodeURIComponent(visitorsReturn) %>">
                <code title="<%= guestId %>"><%= shortGuestId %></code>
              </a>
            </td>
            <td><%= Number(row.answers_count || 0) %></td>
            <td><%= Number(row.questions_count || 0) %></td>
            <td><%= Number(row.groups_count || 0) %></td>
            <td><%= row.latest_group_name || '-' %></td>
            <td><%= formatAdminDate(row.first_seen_at) %></td>
            <td><%= formatAdminDate(row.last_seen_at) %></td>
            <td>
              <form method="post" action="/admin/guests/<%= encodeURIComponent(guestId) %>/delete" onsubmit="return confirm('Delete this guest and all related responses?')">
                <input type="hidden" name="returnTo" value="<%= visitorsReturn %>">
                <button class="secondary" type="submit">Delete guest</button>
              </form>
            </td>
          </tr>
        <% }) %>
      <% } %>
    </tbody>
  </table>
  <%- include('partials/admin_pagination', {
    basePath: '/admin/overview',
    pageParamName: 'visitorPage',
    currentPage: currentVisitorPage,
    totalPages: totalVisitorPages,
    perPage: visitorProfilesPerPage,
    label: 'Visitors',
    extraParams: { groupPage: currentGroupPage, usersPage: currentUserPage, namedGuestPage: currentNamedGuestPage },
    anchorId: 'admin-visitors'
  }) %>

</div>

<script>
  function promptEmailReveal(formId) {
    const form = document.getElementById(formId);
    if (!form) return;
    const adminPassword = window.prompt("Enter your admin password to view this email:");
    if (!adminPassword) return;
    const passwordInput = form.querySelector('input[name=\"adminPassword\"]');
    if (!passwordInput) return;
    passwordInput.value = adminPassword;
    form.submit();
  }
</script>

<%- include('partials/footer') %>
