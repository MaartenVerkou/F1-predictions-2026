<%- include('partials/header', { title: `Admin guest: ${namedGuestProfile?.display_name || guestId}`, user }) %>
<%- include('partials/admin_nav', { active: 'overview' }) %>
<% const formatAdminDate = (value) => {
  if (!value) return '-';
  if (typeof formatAdminDateTime === 'function') return formatAdminDateTime(value);
  const date = new Date(value);
  return Number.isNaN(date.getTime()) ? '-' : date.toLocaleString();
}; %>

<div class="card admin-page-card">
  <div class="admin-page-header">
    <h1>Guest overview</h1>
    <div class="admin-actions">
      <a class="link" href="<%= returnTo %>">&lt; Back to admin overview</a>
      <form method="post" action="/admin/guests/<%= encodeURIComponent(guestId) %>/delete" onsubmit="return confirm('Delete this guest and all related responses?')">
        <input type="hidden" name="returnTo" value="<%= returnTo %>">
        <button class="secondary" type="submit">Delete guest</button>
      </form>
    </div>
  </div>

  <h2><%= namedGuestProfile ? "Named guest" : "Guest ID" %></h2>
  <% if (namedGuestProfile) { %>
    <p style="margin:0 0 6px;"><strong><%= namedGuestProfile.display_name %></strong></p>
  <% } %>
  <p style="margin-top:0;"><code class="admin-question-code"><%= guestId %></code></p>

  <div class="admin-table-scroll" role="region" aria-label="Guest details table" tabindex="0">
  <table class="table compact admin-detail-table">
    <tbody>
      <tr>
        <th>Total responses</th>
        <td><%= Number(guestStats?.response_count || 0) %></td>
      </tr>
      <tr>
        <th>Groups with responses</th>
        <td><%= Number(guestStats?.groups_count || 0) %></td>
      </tr>
      <tr>
        <th>Questions answered</th>
        <td><%= Number(guestStats?.questions_count || 0) %></td>
      </tr>
      <tr>
        <th>First seen</th>
        <td><%= formatAdminDate(guestStats?.first_seen_at) %></td>
      </tr>
      <tr>
        <th>Last response</th>
        <td><%= formatAdminDate(guestStats?.last_seen_at) %></td>
      </tr>
    </tbody>
  </table>
  </div>

  <h2>Groups touched</h2>
  <div class="admin-table-scroll" role="region" aria-label="Guest groups table" tabindex="0">
  <table class="table compact admin-table-detail">
    <thead>
      <tr>
        <th>Group</th>
        <th>Responses</th>
        <th>Questions</th>
        <th>Last updated</th>
      </tr>
    </thead>
    <tbody>
      <% if (!groups || groups.length === 0) { %>
        <tr>
          <td colspan="4" class="muted">No groups.</td>
        </tr>
      <% } else { %>
        <% groups.forEach(row => { %>
          <% const groupPath = Number(row.is_global) === 1 ? '/global' : `/groups/${row.group_id}`; %>
          <tr>
            <td><a class="link" href="<%= groupPath %>"><%= row.group_name %></a></td>
            <td><%= Number(row.responses_count || 0) %></td>
            <td><%= Number(row.questions_count || 0) %></td>
            <td><%= formatAdminDate(row.last_updated_at) %></td>
          </tr>
        <% }) %>
      <% } %>
    </tbody>
  </table>
  </div>

  <h2>Latest responses</h2>
  <div class="admin-table-scroll" role="region" aria-label="Latest guest responses table" tabindex="0">
  <table class="table compact admin-table-detail">
    <thead>
      <tr>
        <th>Group</th>
        <th>Question</th>
        <th>Answer</th>
        <th>Updated</th>
      </tr>
    </thead>
    <tbody>
      <% if (!responses || responses.length === 0) { %>
        <tr>
          <td colspan="4" class="muted">No responses yet.</td>
        </tr>
      <% } else { %>
        <% responses.forEach(row => { %>
          <% const groupPath = Number(row.is_global) === 1 ? '/global' : `/groups/${row.group_id}`; %>
          <tr>
            <td><a class="link" href="<%= groupPath %>"><%= row.group_name %></a></td>
            <td><code class="admin-question-code"><%= row.question_id %></code></td>
            <td><code class="admin-question-code"><%= row.answer %></code></td>
            <td><%= formatAdminDate(row.updated_at) %></td>
          </tr>
        <% }) %>
      <% } %>
    </tbody>
  </table>
  </div>
  <p class="muted admin-page-note">Showing latest <%= responses.length %> rows (max 500).</p>
</div>

<%- include('partials/footer') %>
