<% if (leaderboardCard && Array.isArray(leaderboardCard.rows) && leaderboardCard.rows.length > 0) { %>
  <div class="card leaderboard-preview-card <%= leaderboardCard.className || '' %>">
    <div class="leaderboard-preview-header">
      <span class="badge leaderboard-preview-badge"><%= leaderboardCard.badge %></span>
      <% if (leaderboardCard.href && leaderboardCard.cta) { %>
        <a class="link leaderboard-preview-link <%= leaderboardCard.ctaPlacement === 'mobile-bottom' ? 'leaderboard-preview-link-mobile-top' : '' %>" href="<%= leaderboardCard.href %>"><%= leaderboardCard.cta %></a>
      <% } %>
    </div>

    <div class="leaderboard-preview-list" role="list" aria-label="<%= leaderboardCard.ariaLabel || leaderboardCard.badge %>">
      <% leaderboardCard.rows.forEach((row) => { %>
        <% const delta = row.latestRoundDelta || null; %>
        <% const rankDelta = delta ? Number(delta.rankDelta || 0) : null; %>
        <% const deltaClass = rankDelta > 0 ? 'is-positive' : (rankDelta < 0 ? 'is-negative' : ''); %>
        <% const deltaLabel = rankDelta == null
          ? t('leaderboard.no_movement_data')
          : (rankDelta === 0 ? t('leaderboard.no_rank_change') : `${t('leaderboard.rank_change_aria')}: ${rankDelta > 0 ? '+' : ''}${rankDelta}`); %>
        <% const deltaText = rankDelta == null || rankDelta === 0 ? '-' : `${rankDelta > 0 ? '^' : 'v'}${Math.abs(rankDelta)}`; %>
        <div
          class="leaderboard-preview-row <%= row.rank <= 3 ? `is-top-${row.rank}` : '' %>"
          role="listitem"
        >
          <div class="leaderboard-preview-rank"><%= row.rank %></div>
          <div class="leaderboard-preview-delta <%= deltaClass %>" aria-label="<%= deltaLabel %>"><%= deltaText %></div>
          <div class="leaderboard-preview-name"><strong><%= row.name %></strong></div>
          <div class="leaderboard-preview-points"><strong><%= row.total %></strong></div>
        </div>
      <% }) %>
    </div>

    <% if (leaderboardCard.href && leaderboardCard.cta && leaderboardCard.ctaPlacement === 'mobile-bottom') { %>
      <a class="link leaderboard-preview-link leaderboard-preview-link-bottom" href="<%= leaderboardCard.href %>"><%= leaderboardCard.cta %></a>
    <% } %>
  </div>
<% } %>
