<%
  const safeCurrentPage = typeof currentPage === "undefined" ? 1 : currentPage;
  const safeTotalPages = typeof totalPages === "undefined" ? 1 : totalPages;
  const safePageParamName =
    typeof pageParamName === "undefined" ? "page" : pageParamName;
  const safeBasePath = typeof basePath === "undefined" ? "" : basePath;
  const safeExtraParams =
    typeof extraParams === "undefined" ? {} : extraParams;
  const safeAnchorId = typeof anchorId === "undefined" ? "" : anchorId;
  const safeLabel = typeof label === "undefined" ? "Page" : label;
  const safePerPage = typeof perPage === "undefined" ? 0 : perPage;
  const safeShowSummary =
    typeof showSummary === "undefined" ? true : Boolean(showSummary);
  const safeMaxVisiblePages =
    typeof maxVisiblePages === "undefined" ? 3 : Number(maxVisiblePages);
  const safeFirstLabel = typeof firstLabel === "undefined" ? "<<" : String(firstLabel);
  const safePrevLabel = typeof prevLabel === "undefined" ? "<" : String(prevLabel);
  const safeNextLabel = typeof nextLabel === "undefined" ? ">" : String(nextLabel);
  const safeLastLabel = typeof lastLabel === "undefined" ? ">>" : String(lastLabel);

  const current = Math.max(1, Number(safeCurrentPage || 1));
  const total = Math.max(1, Number(safeTotalPages || 1));
  const param = String(safePageParamName || "page");
  const path = String(safeBasePath || "");
  const params =
    safeExtraParams && typeof safeExtraParams === "object" ? safeExtraParams : {};
  const fragment = String(safeAnchorId || "").trim();
  const sectionLabel = String(safeLabel || "Page");
  const pageSize = Number(safePerPage || 0);
  const visiblePageCount =
    Number.isFinite(safeMaxVisiblePages) && safeMaxVisiblePages >= 3
      ? Math.floor(safeMaxVisiblePages)
      : 9;

  const buildHref = (pageNumber) => {
    const qp = new URLSearchParams();
    Object.entries(params).forEach(([key, value]) => {
      if (key === param) return;
      if (value == null || value === "") return;
      qp.set(String(key), String(value));
    });
    qp.set(param, String(pageNumber));
    const baseHref = `${path}?${qp.toString()}`;
    return fragment ? `${baseHref}#${encodeURIComponent(fragment)}` : baseHref;
  };

  const buildPageItems = () => {
    if (total <= visiblePageCount) {
      return Array.from({ length: total }, (_, i) => i + 1);
    }
    const items = [];
    const add = (value) => {
      if (items[items.length - 1] === value) return;
      items.push(value);
    };
    add(1);

    const innerWindow = Math.max(1, visiblePageCount - 2);
    const sideWindow = Math.floor(innerWindow / 2);
    let start = Math.max(2, current - sideWindow);
    let end = Math.min(total - 1, start + innerWindow - 1);
    start = Math.max(2, end - innerWindow + 1);

    if (start > 2) add("...");
    for (let page = start; page <= end; page += 1) add(page);
    if (end < total - 1) add("...");
    add(total);

    return items;
  };

  const pageItems = buildPageItems();
%>
<div class="admin-pagination">
  <% if (current > 1) { %>
    <a class="admin-page-link" href="<%= buildHref(1) %>"><%= safeFirstLabel %></a>
    <a class="admin-page-link" href="<%= buildHref(current - 1) %>"><%= safePrevLabel %></a>
  <% } else { %>
    <span class="admin-page-link is-disabled"><%= safeFirstLabel %></span>
    <span class="admin-page-link is-disabled"><%= safePrevLabel %></span>
  <% } %>

  <% pageItems.forEach((item) => { %>
    <% if (item === "...") { %>
      <span class="admin-page-ellipsis">...</span>
    <% } else if (Number(item) === current) { %>
      <span class="admin-page-link is-active"><%= item %></span>
    <% } else { %>
      <a class="admin-page-link" href="<%= buildHref(item) %>"><%= item %></a>
    <% } %>
  <% }) %>

  <% if (current < total) { %>
    <a class="admin-page-link" href="<%= buildHref(current + 1) %>"><%= safeNextLabel %></a>
    <a class="admin-page-link" href="<%= buildHref(total) %>"><%= safeLastLabel %></a>
  <% } else { %>
    <span class="admin-page-link is-disabled"><%= safeNextLabel %></span>
    <span class="admin-page-link is-disabled"><%= safeLastLabel %></span>
  <% } %>

  <% if (safeShowSummary) { %>
    <span class="muted admin-pagination-summary">
      <%= sectionLabel %> page <%= current %> of <%= total %><%= pageSize > 0 ? ` (${pageSize}/page)` : "" %>
    </span>
  <% } %>
</div>
