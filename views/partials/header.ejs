<!DOCTYPE html>
<% const brandTagline = "Predict the Formula 1 Season"; %>
<% const devSessionMode = String(typeof devIdentityMode === 'string' ? devIdentityMode : '').trim().toLowerCase(); %>
<% const devMode = user
  ? (user.is_admin ? 'admin' : 'member')
  : (devSessionMode === 'named_guest' ? 'guest' : 'visitor'); %>
<% const activePath = String(typeof currentPath === 'string' ? currentPath : ''); %>
<% const isAdminActive = activePath.startsWith('/admin'); %>
<% const isDashboardActive = activePath.startsWith('/dashboard'); %>
<% const isAccountActive = activePath.startsWith('/account'); %>
<% const countdownCloseAt = closeAt || '2026-03-05T23:59:59'; %>
<% const countdownCloseDate = new Date(countdownCloseAt); %>
<% const countdownTotalSeconds = Number.isFinite(countdownCloseDate.getTime())
  ? Math.max(0, Math.floor((countdownCloseDate.getTime() - Date.now()) / 1000))
  : null; %>
<% const countdownInitiallyClosed = countdownTotalSeconds !== null && countdownTotalSeconds <= 0; %>
<% const countdownInitialText = (() => {
  if (countdownTotalSeconds === null) return '--';
  if (countdownInitiallyClosed) return t('header.countdown_closed');
  if (countdownTotalSeconds < 24 * 60 * 60) {
    const hours = Math.floor(countdownTotalSeconds / 3600);
    const minutes = Math.floor((countdownTotalSeconds % 3600) / 60);
    const seconds = countdownTotalSeconds % 60;
    return `${hours}H ${String(minutes).padStart(2, '0')}M ${String(seconds).padStart(2, '0')}S`;
  }
  const totalMinutes = Math.floor(countdownTotalSeconds / 60);
  const days = Math.floor(totalMinutes / (60 * 24));
  const hours = Math.floor((totalMinutes % (60 * 24)) / 60);
  const minutes = totalMinutes % 60;
  return `${days}d ${hours}h ${minutes}m`;
})(); %>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script>
      (function () {
        var root = document.documentElement;
        var prefersDark = window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches;
        var theme = prefersDark ? "dark" : "light";
        try {
          var saved = localStorage.getItem("theme");
          if (saved === "dark" || saved === "light") {
            theme = saved;
          }
        } catch (e) {}
        root.setAttribute("data-theme", theme);
      })();
    </script>
    <title><%= companyName %></title>
    <meta property="og:description" content="<%= brandTagline %>" />
    <meta property="og:image" content="<%= `${baseUrl}${assetPath('/assets/brand/logo-og-image-dark.jpg')}` %>" />
    <meta property="og:image:alt" content="<%= companyName %> preview image" />
    <link rel="icon" type="image/png" href="<%= assetPath('/assets/brand/logo-header.png') %>" />
    <link rel="shortcut icon" type="image/png" href="<%= assetPath('/assets/brand/logo-header.png') %>" />
    <link rel="apple-touch-icon" href="<%= assetPath('/assets/brand/logo-header.png') %>" />
    <link rel="stylesheet" href="<%= assetPath('/styles.css') %>" />
    <script src="<%= assetPath('/app.js') %>" defer></script>
  </head>
  <body class="<%= isDevelopment ? 'has-dev-toolbar' : '' %>">
    <% if (isDevelopment) { %>
      <div class="dev-toolbar" aria-label="Development quick switch">
        <div class="dev-toolbar-inner">
          <span class="dev-toolbar-label">Dev</span>
          <div class="dev-switcher">
            <form method="post" action="/dev/switch-user">
              <input type="hidden" name="mode" value="admin" />
              <input type="hidden" name="redirectTo" value="<%= currentPath %>" />
              <button type="submit" class="secondary dev-switch-btn <%= devMode === 'admin' ? 'is-active' : '' %>">Admin</button>
            </form>
            <form method="post" action="/dev/switch-user">
              <input type="hidden" name="mode" value="member" />
              <input type="hidden" name="redirectTo" value="<%= currentPath %>" />
              <button type="submit" class="secondary dev-switch-btn <%= devMode === 'member' ? 'is-active' : '' %>">Member</button>
            </form>
            <form method="post" action="/dev/switch-user">
              <input type="hidden" name="mode" value="visitor" />
              <input type="hidden" name="redirectTo" value="<%= currentPath %>" />
              <button type="submit" class="secondary dev-switch-btn <%= devMode === 'visitor' ? 'is-active' : '' %>">Visitor</button>
            </form>
            <form method="post" action="/dev/switch-user">
              <input type="hidden" name="mode" value="guest" />
              <input type="hidden" name="redirectTo" value="<%= currentPath %>" />
              <button type="submit" class="secondary dev-switch-btn <%= devMode === 'guest' ? 'is-active' : '' %>">Guest</button>
            </form>
          </div>
        </div>
      </div>
    <% } %>
    <header>
      <div class="header-inner">
        <div class="header-left">
          <a class="header-brand" href="/" aria-label="<%= companyName %>">
            <span class="brand-lockup">
              <img
                class="brand-logo"
                src="<%= assetPath('/assets/brand/logo-header-light-96.png') %>"
                data-logo-light="<%= assetPath('/assets/brand/logo-header-light-96.png') %>"
                data-logo-dark="<%= assetPath('/assets/brand/logo-header-dark-96.png') %>"
                alt="Wheel of Knowledge logo"
                width="50"
                height="50"
              />
              <span class="brand-text">
                <span class="brand-line brand-line-top">WHEEL OF</span>
                <span class="brand-line brand-line-knowledge">KNOWLEDGE</span>
                <span class="brand-divider" aria-hidden="true"></span>
                <span class="brand-tagline"><%= brandTagline %></span>
              </span>
            </span>
          </a>
        </div>
        <div class="header-center" data-header-center>
          <div
            class="countdown <%= countdownInitiallyClosed ? 'is-closed' : '' %>"
            data-close-date="<%= countdownCloseAt %>"
            data-countdown-prefix="<%= t('header.countdown_prefix') %>"
            data-countdown-closed="<%= t('header.countdown_closed') %>"
            data-countdown-closed-compact="<%= t('header.countdown_closed_short') %>"
          >
            <span class="muted"><%= t('header.countdown_prefix') %></span>
            <strong class="countdown-value">
              <% if (countdownInitiallyClosed) { %>
                <span class="countdown-closed-full"><%= t('header.countdown_closed') %></span>
                <span class="countdown-closed-compact"><%= t('header.countdown_closed_short') %></span>
              <% } else { %>
                <%= countdownInitialText %>
              <% } %>
            </strong>
          </div>
        </div>
        <div class="header-right" data-header-right>
          <button
            type="button"
            class="header-menu-toggle icon-btn"
            data-header-menu-toggle
            aria-expanded="false"
            aria-controls="header-actions"
            aria-label="Toggle menu"
            title="Toggle menu"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M4 7h16M4 12h16M4 17h16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path>
            </svg>
          </button>
          <div class="header-actions" id="header-actions" data-header-menu>
            <div class="header-main-links">
              <% if (user) { %>
                <% if (user.is_admin) { %>
                  <a class="link header-action-link header-link-admin <%= isAdminActive ? 'is-active' : '' %>" href="/admin/overview" aria-label="<%= t('header.admin') %>" title="<%= t('header.admin') %>">
                    <svg class="header-nav-icon header-nav-icon-admin" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                      <path d="M12 3.5 18.5 6v5.2c0 3.9-2.6 7.6-6.5 9.3-3.9-1.7-6.5-5.4-6.5-9.3V6L12 3.5Z"></path>
                      <path d="M12 8.2 13.1 10.4l2.4.3-1.7 1.7.4 2.4-2.2-1.2-2.2 1.2.4-2.4-1.7-1.7 2.4-.3L12 8.2Z"></path>
                    </svg>
                    <span class="header-link-label"><%= t('header.admin') %></span>
                  </a>
                <% } %>
                <a class="link header-action-link header-link-dashboard <%= isDashboardActive ? 'is-active' : '' %>" href="/dashboard" aria-label="<%= t('header.dashboard') %>" title="<%= t('header.dashboard') %>">
                  <svg class="header-nav-icon header-nav-icon-dashboard" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path d="M4.5 4.5h5.7v5.7H4.5V4.5Z"></path>
                    <path d="M13.8 4.5h5.7v5.7h-5.7V4.5Z"></path>
                    <path d="M4.5 13.8h5.7v5.7H4.5v-5.7Z"></path>
                    <path d="M13.8 13.8h5.7v5.7h-5.7v-5.7Z"></path>
                  </svg>
                  <span class="header-link-label"><%= t('header.dashboard') %></span>
                </a>
                <a class="link header-action-link header-link-account header-link-compact <%= isAccountActive ? 'is-active' : '' %>" href="/account" aria-label="<%= t('account.page_title') %>" title="<%= `${t('account.page_title')}: ${user.name}` %>">
                  <svg class="header-nav-icon header-nav-icon-account" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <circle cx="12" cy="8" r="3.5"></circle>
                    <path d="M5.5 19.5c.9-3.6 3.2-5.5 6.5-5.5s5.6 1.9 6.5 5.5"></path>
                  </svg>
                  <span class="header-link-label"><%= t('account.page_title') %></span>
                </a>
              <% } else { %>
                <a class="link header-action-link header-link-login" href="/login">
                  <svg class="header-nav-icon header-nav-icon-login" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path d="M13 4H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h6"></path>
                    <path d="M10 12h9"></path>
                    <path d="m16 8 4 4-4 4"></path>
                  </svg>
                  <span class="header-link-label"><%= t('header.login') %></span>
                </a>
              <% } %>
            </div>
            <div class="header-icon-actions">
              <details class="lang-menu">
              <summary class="icon-btn header-menu-row" aria-label="<%= t('header.language') %>" title="<%= t('header.language') %>">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="1.7"></circle>
                  <path d="M3 12h18M12 3a15 15 0 0 1 0 18M12 3a15 15 0 0 0 0 18" fill="none" stroke="currentColor" stroke-width="1.5"></path>
                </svg>
                <span class="header-menu-row-label"><%= t('header.language') %></span>
              </summary>
              <div class="lang-popover">
                <form method="post" action="/language" class="lang-list-form">
                  <input type="hidden" name="redirectTo" value="<%= currentPath %>" />
                  <% supportedLocales.forEach(({ code, label }) => { %>
                    <button
                      type="submit"
                      name="locale"
                      value="<%= code %>"
                      class="<%= locale === code ? 'lang-option is-active' : 'lang-option' %>"
                    >
                      <%= label %>
                    </button>
                  <% }) %>
                </form>
              </div>
              </details>
              <button
                type="button"
                class="secondary theme-toggle icon-btn header-menu-row"
                data-theme-toggle
                data-label-dark="<%= t('theme.dark_mode') %>"
                data-label-light="<%= t('theme.light_mode') %>"
                aria-label="<%= t('theme.dark_mode') %>"
                title="<%= t('theme.dark_mode') %>"
              >
                <span class="theme-icon theme-icon-moon" aria-hidden="true">
                  <svg viewBox="0 0 24 24">
                    <defs>
                      <mask id="theme-moon-cutout">
                        <rect width="24" height="24" fill="white"></rect>
                        <circle cx="16" cy="12" r="7.1" fill="black"></circle>
                      </mask>
                    </defs>
                    <circle cx="12" cy="12" r="9" fill="currentColor" mask="url(#theme-moon-cutout)"></circle>
                  </svg>
                </span>
                <span class="theme-icon theme-icon-sun" aria-hidden="true">
                  <svg viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="1.7"></circle>
                    <path d="M12 2.5v3M12 18.5v3M2.5 12h3M18.5 12h3M5.2 5.2l2.1 2.1M16.7 16.7l2.1 2.1M18.8 5.2l-2.1 2.1M7.3 16.7l-2.1 2.1" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
                  </svg>
                </span>
                <span class="header-menu-row-label" data-theme-toggle-label><%= t('theme.dark_mode') %></span>
              </button>
            </div>
          </div>
        </div>
      </div>
    </header>
    <main>
