<%- include('partials/header', { title: `Admin user: ${targetUser.name}`, user }) %>
<%- include('partials/admin_nav', { active: 'overview' }) %>
<% const formatAdminDate = (value) => {
  if (!value) return '-';
  if (typeof formatAdminDateTime === 'function') return formatAdminDateTime(value);
  const date = new Date(value);
  return Number.isNaN(date.getTime()) ? '-' : date.toLocaleString();
}; %>

<div class="card admin-page-card">
  <div class="admin-page-header">
    <h1>User overview</h1>
    <a class="link" href="<%= returnTo %>">&lt; Back to admin overview</a>
  </div>

  <h2><%= targetUser.name %></h2>
  <div class="admin-table-scroll" role="region" aria-label="User details table" tabindex="0">
  <table class="table compact admin-detail-table">
    <tbody>
      <tr>
        <th>User ID</th>
        <td><%= targetUser.id %></td>
      </tr>
      <tr>
        <th>Email</th>
        <td><%= targetUser.email %></td>
      </tr>
      <tr>
        <th>Admin</th>
        <td><%= targetUser.is_admin ? 'Yes' : 'No' %></td>
      </tr>
      <tr>
        <th>Verified</th>
        <td><%= targetUser.is_verified ? 'Yes' : 'No' %></td>
      </tr>
      <tr>
        <th>Created</th>
        <td><%= formatAdminDate(targetUser.created_at) %></td>
      </tr>
      <tr>
        <th>Verified at</th>
        <td><%= formatAdminDate(targetUser.verified_at) %></td>
      </tr>
      <tr>
        <th>Total responses</th>
        <td><%= Number(responseStats?.response_count || 0) %></td>
      </tr>
      <tr>
        <th>Groups with responses</th>
        <td><%= Number(responseStats?.groups_count || 0) %></td>
      </tr>
      <tr>
        <th>Questions answered</th>
        <td><%= Number(responseStats?.questions_count || 0) %></td>
      </tr>
      <tr>
        <th>Last response</th>
        <td><%= formatAdminDate(responseStats?.last_updated_at) %></td>
      </tr>
    </tbody>
  </table>
  </div>

  <h2>Memberships</h2>
  <div class="admin-table-scroll" role="region" aria-label="User memberships table" tabindex="0">
  <table class="table compact admin-table-detail">
    <thead>
      <tr>
        <th>Group</th>
        <th>Role</th>
        <th>Joined</th>
      </tr>
    </thead>
    <tbody>
      <% if (!memberships || memberships.length === 0) { %>
        <tr>
          <td colspan="3" class="muted">No memberships.</td>
        </tr>
      <% } else { %>
        <% memberships.forEach(row => { %>
          <% const groupPath = Number(row.is_global) === 1 ? '/global' : `/groups/${row.group_id}`; %>
          <tr>
            <td><a class="link" href="<%= groupPath %>"><%= row.group_name %></a></td>
            <td><%= row.role %></td>
            <td><%= formatAdminDate(row.joined_at) %></td>
          </tr>
        <% }) %>
      <% } %>
    </tbody>
  </table>
  </div>

  <h2>Latest responses</h2>
  <div class="admin-table-scroll" role="region" aria-label="Latest user responses table" tabindex="0">
  <table class="table compact admin-table-detail">
    <thead>
      <tr>
        <th>Group</th>
        <th>Question</th>
        <th>Answer</th>
        <th>Updated</th>
      </tr>
    </thead>
    <tbody>
      <% if (!responses || responses.length === 0) { %>
        <tr>
          <td colspan="4" class="muted">No responses yet.</td>
        </tr>
      <% } else { %>
        <% responses.forEach(row => { %>
          <% const groupPath = Number(row.is_global) === 1 ? '/global' : `/groups/${row.group_id}`; %>
          <tr>
            <td><a class="link" href="<%= groupPath %>"><%= row.group_name %></a></td>
            <td><code class="admin-question-code"><%= row.question_id %></code></td>
            <td><code class="admin-question-code"><%= row.answer %></code></td>
            <td><%= formatAdminDate(row.updated_at) %></td>
          </tr>
        <% }) %>
      <% } %>
    </tbody>
  </table>
  </div>
  <p class="muted admin-page-note">Showing latest <%= responses.length %> rows (max 500).</p>
</div>

<%- include('partials/footer') %>
