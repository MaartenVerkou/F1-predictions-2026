<%- include('partials/header', { title: t('admin_actuals.page_title'), user }) %>
<%- include('partials/admin_nav', { active: 'actuals' }) %>
<% const formatAdminDate = (value) => {
  if (!value) return '-';
  if (typeof formatAdminDateTime === 'function') return formatAdminDateTime(value);
  const date = new Date(value);
  return Number.isNaN(date.getTime()) ? '-' : date.toLocaleString();
};
const reviewStatusLabel = (status) =>
  status === 'pending' ? t('admin_actuals.status_pending') : t('admin_actuals.status_reviewed');
const targetTimingLabel = (target) => {
  if (!target) return '';
  if (target.timing === 'past') return t('admin_actuals.timing_past');
  if (target.timing === 'future') return t('admin_actuals.timing_future');
  return t('admin_actuals.timing_current_race');
};
const targetReviewLabel = (target) => {
  if (!target) return '';
  if (target.reviewStatus === 'pending') return t('admin_actuals.needs_review');
  if (target.reviewStatus === 'reviewed') return t('admin_actuals.reviewed');
  return '';
};
const snapshotLabel = (target) =>
  target?.snapshotLabel || `R${target?.roundNumber || ''} - ${target?.raceName || ''}`;
const pendingReviewSummary =
  (pendingReviewTargets || []).length === 1
    ? t('admin_actuals.review_backlog_one')
    : t('admin_actuals.review_backlog_many', { count: (pendingReviewTargets || []).length });
%>

<div class="card admin-page-card admin-actuals-page">
  <h1><%= t('admin_actuals.heading') %></h1>
  <p class="muted admin-page-intro"><%= t('admin_actuals.intro') %></p>

  <% if (saveError) { %>
    <div class="alert"><%= saveError %></div>
  <% } %>
  <% if (saveSuccess) { %>
    <div class="alert admin-success"><%= saveSuccess %></div>
  <% } %>

  <% if ((pendingReviewTargets || []).length > 0) { %>
    <div class="alert admin-alert-spaced">
      <strong><%= t('admin_actuals.review_backlog_label') %></strong> <%= pendingReviewSummary %>
      <div class="muted admin-alert-detail">
        <%= pendingReviewTargets.map((target) => `R${target.roundNumber} ${target.raceName}`).join(' | ') %>
      </div>
    </div>
  <% } %>

  <% if (liveActualsReview) { %>
    <div class="admin-status-panel admin-actuals-status-panel">
      <div class="admin-status-title"><%= t('admin_actuals.live_scoring_source') %>: <%= `R${liveActualsReview.roundNumber} - ${liveActualsReview.roundName}` %></div>
      <div class="muted admin-status-line">
        <span><%= t('admin_actuals.status_label') %>: <strong><%= reviewStatusLabel(liveActualsReview.reviewStatus) %></strong></span>
        <span><%= t('admin_actuals.last_sync_label') %>: <strong><%= formatAdminDate(liveActualsReview.updatedAt) %></strong></span>
        <% if (liveActualsReview.reviewStatus !== 'pending' && liveActualsReview.reviewedAt) { %>
          <span><%= t('admin_actuals.reviewed_label') %>: <strong><%= formatAdminDate(liveActualsReview.reviewedAt) %></strong></span>
        <% } %>
      </div>
      <% if (actualsTarget === 'current' && liveActualsReview.reviewStatus === 'pending') { %>
        <form method="post" action="/admin/actuals/review" class="admin-inline-form admin-status-action">
          <input type="hidden" name="snapshotId" value="<%= liveActualsReview.snapshotId %>" />
          <input type="hidden" name="target" value="current" />
          <button type="submit" class="secondary"><%= t('admin_actuals.mark_latest_reviewed') %></button>
        </form>
      <% } %>
    </div>
  <% } %>

  <% if (actualsTarget === 'current') { %>
    <div class="admin-actions admin-actuals-actions">
      <form method="post" action="/admin/actuals/autofill-current-season" class="admin-inline-form">
        <button type="submit" class="secondary"><%= t('admin_actuals.preview_autofill') %></button>
      </form>
      <form method="post" action="/admin/actuals/run-auto-update" class="admin-inline-form">
        <button type="submit" class="secondary"><%= t('admin_actuals.run_sync_now') %></button>
      </form>
      <span class="muted admin-actions-help"><%= t('admin_actuals.sync_help') %></span>
    </div>
  <% } %>

  <form method="get" action="/admin/actuals" class="admin-target-form">
    <label class="admin-field admin-target-field">
      <span class="muted"><%= t('admin_actuals.target_label') %></span>
      <select name="target" onchange="this.form.submit()">
        <option value="current" <%= actualsTarget === 'current' ? 'selected' : '' %>><%= t('admin_actuals.current_live_actuals') %></option>
        <% raceTargets.forEach((target) => { %>
          <% const timing = targetTimingLabel(target); %>
          <% const review = targetReviewLabel(target); %>
          <option value="<%= target.key %>" <%= actualsTarget === target.key ? 'selected' : '' %>>
            <%= `R${target.roundNumber} - ${target.raceName}` %><%= timing ? ` (${timing})` : '' %><%= review ? ` | ${review}` : '' %>
          </option>
        <% }) %>
      </select>
    </label>
    <% if (requiresPastUnlock) { %>
      <input type="hidden" name="unlockPast" value="0" />
    <% } else if (selectedRaceTarget && selectedRaceTarget.timing === 'past') { %>
      <input type="hidden" name="unlockPast" value="1" />
    <% } %>
    <noscript><button type="submit" class="secondary"><%= t('admin_actuals.open_target') %></button></noscript>
  </form>

  <% if (selectedRaceTarget && selectedRaceTarget.timing === 'past' && requiresPastUnlock) { %>
    <div class="alert admin-alert-spaced">
      <%= t('admin_actuals.past_race_warning_prefix') %> <strong><%= `R${selectedRaceTarget.roundNumber} - ${selectedRaceTarget.raceName}` %></strong>.
      <form method="get" action="/admin/actuals" class="admin-inline-form admin-alert-action">
        <input type="hidden" name="target" value="<%= actualsTarget %>" />
        <input type="hidden" name="unlockPast" value="1" />
        <button type="submit" class="secondary"><%= t('admin_actuals.continue_make_changes') %></button>
      </form>
    </div>
  <% } %>

  <% if (isFutureRaceTarget) { %>
    <div class="alert admin-alert-spaced"><%= t('admin_actuals.future_race_warning') %></div>
  <% } %>

  <% if (selectedRaceTarget && selectedRaceTarget.snapshotId) { %>
    <div class="admin-status-panel admin-snapshot-panel">
      <p class="muted admin-status-line">
        <span><%= t('admin_actuals.editing_snapshot') %>: <strong><%= snapshotLabel(selectedRaceTarget) %></strong></span>
      </p>
      <% if (selectedSnapshotMeta) { %>
        <p class="muted admin-status-line">
          <span><%= t('admin_actuals.status_label') %>: <strong><%= reviewStatusLabel(selectedSnapshotMeta.review_status) %></strong></span>
          <span><%= t('admin_actuals.last_sync_label') %>: <strong><%= formatAdminDate(selectedSnapshotMeta.updated_at || selectedSnapshotMeta.created_at) %></strong></span>
          <% if (selectedSnapshotMeta.review_status === 'reviewed' && selectedSnapshotMeta.reviewed_at) { %>
            <span><%= t('admin_actuals.reviewed_label') %>: <strong><%= formatAdminDate(selectedSnapshotMeta.reviewed_at) %></strong></span>
          <% } %>
        </p>
        <% if (selectedSnapshotMeta.review_status === 'pending') { %>
          <form method="post" action="/admin/actuals/review" class="admin-inline-form admin-status-action">
            <input type="hidden" name="snapshotId" value="<%= selectedSnapshotMeta.id %>" />
            <input type="hidden" name="target" value="<%= actualsTarget %>" />
            <% if (selectedRaceTarget.timing === 'past' && !requiresPastUnlock) { %>
              <input type="hidden" name="unlockPast" value="1" />
            <% } %>
            <button type="submit" class="secondary"><%= t('admin_actuals.mark_snapshot_reviewed') %></button>
          </form>
        <% } %>
      <% } %>
    </div>
  <% } else if (selectedRaceTarget) { %>
    <p class="muted admin-page-note"><%= t('admin_actuals.no_snapshot_yet_prefix') %> <strong><%= `R${selectedRaceTarget.roundNumber} - ${selectedRaceTarget.raceName}` %></strong>. <%= t('admin_actuals.no_snapshot_yet_suffix') %></p>
  <% } %>

  <form method="post" action="/admin/actuals" data-admin-actuals-form data-initial-dirty="<%= hasDraft ? 'true' : 'false' %>">
    <input type="hidden" name="actualsTarget" value="<%= actualsTarget %>" />
    <% if (selectedRaceTarget && selectedRaceTarget.timing === 'past' && !requiresPastUnlock) { %>
      <input type="hidden" name="unlockPast" value="1" />
    <% } %>
    <% const sourceOptionsFor = (question) => {
      if (question.options_source === 'drivers') return roster.drivers;
      if (question.options_source === 'teams') return roster.teams;
      if (question.options_source === 'races') return races;
      return [];
    }; %>
    <% const multiActualSingleChoiceIds = new Set([
      'most_driver_of_the_day',
      'most_dnfs_driver',
      'destructors_driver',
      'destructors_team',
      'most_points_no_podium',
      'closest_qualifying_teammates'
    ]); %>
    <% const multiActualDriverFieldIds = new Set(['lowest_grid_win_position']); %>
    <fieldset class="admin-fieldset-reset" <%= requiresPastUnlock ? 'disabled' : '' %>>

    <% questions.forEach(question => { 
      const sourceOptions = sourceOptionsFor(question);
      const options = (question.options || []).concat(sourceOptions || []);
      const type = question.type || 'text';
      let saved = actuals[question.id];
      if (saved) {
        try {
          saved = JSON.parse(saved);
        } catch (err) {}
      }
    %>
      <div class="question admin-actuals-question">
        <div class="admin-actuals-question-title"><%= question.prompt %></div>
        <% if (question.helper) { %>
          <div class="muted"><%= question.helper %></div>
        <% } %>

        <% if (type === 'ranking') { 
          const count = Number(question.count) || 3;
          const selections = Array.isArray(saved) ? saved : [];
        %>
          <div class="ranking-group" data-count="<%= count %>">
            <% for (let i = 1; i <= count; i += 1) { %>
              <select class="ranking-select" name="<%= question.id %>_<%= i %>">
                <option value=""><%= t('questions.select_position') %> <%= i %></option>
                <% options.forEach(option => { %>
                  <option value="<%= option %>" <%= selections[i - 1] === option ? 'selected' : '' %>><%= option %></option>
                <% }) %>
              </select>
            <% } %>
          </div>
        <% } else if (type === 'single_choice' && multiActualSingleChoiceIds.has(question.id)) {
          const selections = Array.isArray(saved) ? saved : (saved ? [saved] : []);
        %>
          <div class="checkbox-grid">
            <% options.forEach(option => { %>
              <label class="muted">
                <input type="checkbox" name="<%= question.id %>" value="<%= option %>" <%= selections.includes(option) ? 'checked' : '' %> />
                <%= option %>
              </label>
            <% }) %>
          </div>
        <% } else if (type === 'single_choice') { %>
          <select name="<%= question.id %>">
            <option value=""><%= t('questions.select_one') %></option>
            <% options.forEach(option => { %>
              <option value="<%= option %>" <%= saved === option ? 'selected' : '' %>><%= option %></option>
            <% }) %>
          </select>
        <% } else if (type === 'multi_select') { 
          const selections = Array.isArray(saved) ? saved : [];
        %>
          <div class="checkbox-grid">
            <% options.forEach(option => { %>
              <label class="muted">
                <input type="checkbox" name="<%= question.id %>" value="<%= option %>" <%= selections.includes(option) ? 'checked' : '' %> />
                <%= option %>
              </label>
            <% }) %>
          </div>
        <% } else if (type === 'multi_select_limited') { 
          const dnfByRace = saved?.dnf_by_race || {};
        %>
          <div class="admin-actuals-dnf-card">
            <div class="muted"><%= t('admin_actuals.enter_dnfs_per_race') %></div>
            <div class="actuals-dnf-grid">
              <% races.forEach((race, idx) => { %>
                <label class="muted actuals-dnf-row">
                  <span class="actuals-dnf-race"><%= race %></span>
                  <div class="number-spinner number-spinner-minimal actuals-dnf-spinner" data-number-spinner>
                    <input type="number" min="0" max="99" name="<%= question.id %>_dnf_<%= idx %>" value="<%= dnfByRace[race] ?? '' %>" />
                    <div class="number-spinner-controls">
                      <button type="button" class="number-spinner-btn is-up" data-spinner-step="up" aria-label="<%= t('admin.increase_value') %>" title="<%= t('admin.increase_value') %>">
                        <svg viewBox="0 0 12 12" aria-hidden="true" focusable="false">
                          <path d="M2.25 7.5 6 3.75 9.75 7.5" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>
                        </svg>
                      </button>
                      <button type="button" class="number-spinner-btn is-down" data-spinner-step="down" aria-label="<%= t('admin.decrease_value') %>" title="<%= t('admin.decrease_value') %>">
                        <svg viewBox="0 0 12 12" aria-hidden="true" focusable="false">
                          <path d="M2.25 7.5 6 3.75 9.75 7.5" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>
                        </svg>
                      </button>
                    </div>
                  </div>
                </label>
              <% }) %>
            </div>
          </div>
        <% } else if (type === 'teammate_battle') { 
          const savedObj = saved || {};
        %>
          <div class="inline-actions admin-actuals-control-row">
            <select name="<%= question.id %>_winner" data-toggle-diff="<%= question.id %>">
              <option value=""><%= t('questions.select_winner') %></option>
              <% (question.options || []).forEach(option => { %>
                <option value="<%= option %>" <%= savedObj.winner === option ? 'selected' : '' %>><%= option %></option>
              <% }) %>
              <option value="tie" <%= savedObj.winner === 'tie' ? 'selected' : '' %>><%= t('questions.tie') %></option>
            </select>
            <div class="number-spinner number-spinner-minimal" data-number-spinner>
              <input type="number" name="<%= question.id %>_diff" data-diff-for="<%= question.id %>" placeholder="<%= t('questions.points_diff') %>" min="0" max="999" value="<%= savedObj.diff ?? '' %>" />
              <div class="number-spinner-controls">
                <button type="button" class="number-spinner-btn is-up" data-spinner-step="up" aria-label="<%= t('admin.increase_value') %>" title="<%= t('admin.increase_value') %>">
                  <svg viewBox="0 0 12 12" aria-hidden="true" focusable="false">
                    <path d="M2.25 7.5 6 3.75 9.75 7.5" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>
                </button>
                <button type="button" class="number-spinner-btn is-down" data-spinner-step="down" aria-label="<%= t('admin.decrease_value') %>" title="<%= t('admin.decrease_value') %>">
                  <svg viewBox="0 0 12 12" aria-hidden="true" focusable="false">
                    <path d="M2.25 7.5 6 3.75 9.75 7.5" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>
                </button>
              </div>
            </div>
          </div>
        <% } else if (type === 'boolean_with_optional_driver') { 
          const savedObj = saved || {};
        %>
          <div class="inline-actions admin-actuals-control-row">
            <label class="muted">
              <input type="radio" name="<%= question.id %>" value="yes" <%= savedObj.choice === 'yes' ? 'checked' : '' %> />
              <%= t('questions.yes') %>
            </label>
            <label class="muted">
              <input type="radio" name="<%= question.id %>" value="no" <%= savedObj.choice === 'no' ? 'checked' : '' %> />
              <%= t('questions.no') %>
            </label>
            <select name="<%= question.id %>_driver" data-toggle-driver="<%= question.id %>">
              <option value=""><%= t('questions.select_driver_if_yes') %></option>
              <% roster.drivers.forEach(option => { %>
                <option value="<%= option %>" <%= savedObj.driver === option ? 'selected' : '' %>><%= option %></option>
              <% }) %>
            </select>
          </div>
        <% } else if (type === 'numeric_with_driver') { 
          const savedObj = saved || {};
        %>
          <div class="inline-actions admin-actuals-control-row">
            <div class="number-spinner number-spinner-minimal" data-number-spinner>
              <input type="number" name="<%= question.id %>_value" placeholder="<%= t('questions.number') %>" min="0" max="999" value="<%= savedObj.value ?? '' %>" />
              <div class="number-spinner-controls">
                <button type="button" class="number-spinner-btn is-up" data-spinner-step="up" aria-label="<%= t('admin.increase_value') %>" title="<%= t('admin.increase_value') %>">
                  <svg viewBox="0 0 12 12" aria-hidden="true" focusable="false">
                    <path d="M2.25 7.5 6 3.75 9.75 7.5" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>
                </button>
                <button type="button" class="number-spinner-btn is-down" data-spinner-step="down" aria-label="<%= t('admin.decrease_value') %>" title="<%= t('admin.decrease_value') %>">
                  <svg viewBox="0 0 12 12" aria-hidden="true" focusable="false">
                    <path d="M2.25 7.5 6 3.75 9.75 7.5" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>
                </button>
              </div>
            </div>
            <select name="<%= question.id %>_driver">
              <option value=""><%= t('questions.select_driver') %></option>
              <% roster.drivers.forEach(option => { %>
                <option value="<%= option %>" <%= savedObj.driver === option ? 'selected' : '' %>><%= option %></option>
              <% }) %>
            </select>
          </div>
        <% } else if (type === 'single_choice_with_driver') { 
          const savedObj = saved || {};
          const positionOptions = question.options || [];
          const driverSelections = Array.isArray(savedObj.driver) ? savedObj.driver : (savedObj.driver ? [savedObj.driver] : []);
        %>
          <% if (multiActualDriverFieldIds.has(question.id)) { %>
            <div>
              <select name="<%= question.id %>_value">
                <option value=""><%= t('questions.select_position') %></option>
                <% positionOptions.forEach(option => { %>
                  <option value="<%= option %>" <%= savedObj.value === option ? 'selected' : '' %>><%= option %></option>
                <% }) %>
              </select>
              <div class="checkbox-grid">
                <% roster.drivers.forEach(option => { %>
                  <label class="muted">
                    <input type="checkbox" name="<%= question.id %>_driver" value="<%= option %>" <%= driverSelections.includes(option) ? 'checked' : '' %> />
                    <%= option %>
                  </label>
                <% }) %>
              </div>
            </div>
          <% } else { %>
            <div class="inline-actions admin-actuals-control-row">
              <select name="<%= question.id %>_value">
                <option value=""><%= t('questions.select_position') %></option>
                <% positionOptions.forEach(option => { %>
                  <option value="<%= option %>" <%= savedObj.value === option ? 'selected' : '' %>><%= option %></option>
                <% }) %>
              </select>
              <select name="<%= question.id %>_driver">
                <option value=""><%= t('questions.select_driver') %></option>
                <% roster.drivers.forEach(option => { %>
                  <option value="<%= option %>" <%= savedObj.driver === option ? 'selected' : '' %>><%= option %></option>
                <% }) %>
              </select>
            </div>
          <% } %>
        <% } else if (type === 'boolean') { %>
          <div class="inline-actions admin-actuals-control-row">
            <label class="muted">
              <input type="radio" name="<%= question.id %>" value="yes" <%= saved === 'yes' ? 'checked' : '' %> />
              <%= t('questions.yes') %>
            </label>
            <label class="muted">
              <input type="radio" name="<%= question.id %>" value="no" <%= saved === 'no' ? 'checked' : '' %> />
              <%= t('questions.no') %>
            </label>
          </div>
        <% } else if (type === 'numeric') { %>
          <div class="number-spinner number-spinner-minimal" data-number-spinner>
            <input type="number" name="<%= question.id %>" min="0" max="999" value="<%= saved ?? '' %>" />
            <div class="number-spinner-controls">
              <button type="button" class="number-spinner-btn is-up" data-spinner-step="up" aria-label="<%= t('admin.increase_value') %>" title="<%= t('admin.increase_value') %>">
                <svg viewBox="0 0 12 12" aria-hidden="true" focusable="false">
                  <path d="M2.25 7.5 6 3.75 9.75 7.5" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
              </button>
              <button type="button" class="number-spinner-btn is-down" data-spinner-step="down" aria-label="<%= t('admin.decrease_value') %>" title="<%= t('admin.decrease_value') %>">
                <svg viewBox="0 0 12 12" aria-hidden="true" focusable="false">
                  <path d="M2.25 7.5 6 3.75 9.75 7.5" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
              </button>
            </div>
          </div>
        <% } else if (type === 'textarea') { %>
          <textarea name="<%= question.id %>" rows="3"><%= saved || '' %></textarea>
        <% } else { %>
          <input type="text" name="<%= question.id %>" value="<%= saved || '' %>" />
        <% } %>
      </div>
    <% }) %>

    <div class="questions-save-row admin-actuals-save-row">
      <button type="submit"><%= actualsTarget === 'current' ? t('admin_actuals.save_actuals') : t('admin_actuals.save_snapshot') %></button>
      <span
        class="muted admin-actuals-save-feedback <%= hasDraft ? 'is-visible is-unsaved' : '' %>"
        data-admin-actuals-unsaved-note
        data-unsaved-label="<%= t('questions.autosave_unsaved') %>"
        data-saving-label="<%= t('questions.autosave_saving') %>"
      ><%= hasDraft ? t('questions.autosave_unsaved') : '' %></span>
    </div>
    </fieldset>
  </form>
</div>

<%- include('partials/footer') %>

