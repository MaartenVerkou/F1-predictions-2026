<%- include('partials/header', { title: t('join_guest.claim_secret_legend'), user }) %>

<div class="card join-guest-card">
  <h1><%= t('join_guest.claim_secret_legend') %></h1>
  <p class="muted"><%= t('join_guest.claim_secret_setup_intro', { group_name: group.name }) %></p>

  <% if (error) { %>
    <div class="alert"><%= error %></div>
  <% } %>

  <form method="post" action="/join/<%= code %>/claim-secret" data-claim-secret-setup-form>
    <%- csrfField() %>
    <fieldset class="join-guest-claim-secret">
      <legend><%= t('join_guest.claim_secret_legend') %></legend>
      <label>
        <input type="radio" name="claimSecretMode" value="pin" checked data-claim-secret-mode="pin" />
        <span><%= t('join_guest.claim_pin_option') %></span>
      </label>
      <label>
        <%= t('join_guest.claim_pin_label') %>
        <input
          type="text"
          name="claimPin"
          inputmode="numeric"
          pattern="[0-9]{4,6}"
          minlength="4"
          maxlength="6"
          required
          autocomplete="off"
          placeholder="<%= t('join_guest.claim_pin_placeholder') %>"
        />
      </label>
      <label>
        <input type="radio" name="claimSecretMode" value="passphrase" data-claim-secret-mode="passphrase" />
        <span><%= t('join_guest.claim_passphrase_option') %></span>
      </label>
      <div data-claim-passphrase-fields hidden>
        <label>
          <%= t('join_guest.claim_prompt_label') %>
          <input
            type="text"
            name="claimPrompt"
            maxlength="160"
            value="<%= defaultClaimPrompt || '' %>"
            autocomplete="off"
          />
        </label>
        <label>
          <%= t('join_guest.claim_passphrase_answer_label') %>
          <input
            type="text"
            name="claimPassphraseAnswer"
            maxlength="160"
            autocomplete="off"
            placeholder="<%= t('join_guest.claim_passphrase_answer_placeholder') %>"
          />
        </label>
      </div>
    </fieldset>

    <button type="submit"><%= t('join_guest.save_claim_secret') %></button>
  </form>
</div>

<script>
  (() => {
    const form = document.querySelector("[data-claim-secret-setup-form]");
    if (!form) return;
    const radios = form.querySelectorAll("[data-claim-secret-mode]");
    const passphraseFields = form.querySelector("[data-claim-passphrase-fields]");
    const pinInput = form.querySelector('input[name="claimPin"]');
    const passphraseInput = form.querySelector('input[name="claimPassphraseAnswer"]');
    const updateMode = () => {
      const selectedMode = form.querySelector('input[name="claimSecretMode"]:checked')?.value || "pin";
      const usePassphrase = selectedMode === "passphrase";
      if (passphraseFields) passphraseFields.hidden = !usePassphrase;
      if (pinInput) pinInput.required = !usePassphrase;
      if (passphraseInput) passphraseInput.required = usePassphrase;
    };
    radios.forEach((input) => input.addEventListener("change", updateMode));
    updateMode();
  })();
</script>

<%- include('partials/footer') %>
