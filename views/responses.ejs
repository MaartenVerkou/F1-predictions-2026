<%- include('partials/header', { title: t('responses.page_title'), user }) %>

<div class="card survey-page-card">
  <% const currentGroupPath = (typeof groupBasePath === 'string' && groupBasePath) ? groupBasePath : groupPath(group); %>
  <% const enableMineToggle = Boolean(user); %>
  <div class="page-title-row">
    <h1><%= group.name %>: <%= t('responses.page_title') %></h1>
    <a class="link page-back-link" href="<%= currentGroupPath %>">&lt; <%= t('group.back_to_group') %></a>
  </div>
  <p class="muted"><%= t('responses.subtitle') %></p>
  <% if (enableMineToggle) { %>
    <label class="responses-mine-toggle">
      <input type="checkbox" data-responses-mine-toggle <%= showMineOnly ? 'checked' : '' %> />
      <span><%= t('responses.only_my_responses') %></span>
    </label>
  <% } %>

  <% const questionMap = questions.reduce((acc, q) => { acc[q.id] = q; return acc; }, {}); %>
  <% const yesText = t('questions.yes'); %>
  <% const noText = t('questions.no'); %>
  <% const tieText = t('questions.tie'); %>
  <% const naText = t('responses.na'); %>
  <% const currentUserId = Number(user?.id || 0); %>
  <% const guestViewerAnswers = (typeof viewerGuestAnswers === 'object' && viewerGuestAnswers) ? viewerGuestAnswers : {}; %>
  <% const showMine = Boolean(showMineOnly && enableMineToggle); %>
  <% const focusedMemberData = (typeof focusedMember === 'object' && focusedMember) ? focusedMember : null; %>
  <% const focusedMemberResponsesData = Array.isArray(focusedMemberResponses) ? focusedMemberResponses : []; %>
  <% const responsesByQuestion = responses.reduce((acc, row) => {
      if (!acc[row.question_id]) acc[row.question_id] = [];
      acc[row.question_id].push(row);
      return acc;
    }, {}); %>
  <% const mineQuestionIds = new Set(); %>
  <% if (currentUserId > 0) { %>
    <% Object.entries(responsesByQuestion).forEach(([questionId, rowsForQuestion]) => {
      if (Array.isArray(rowsForQuestion) && rowsForQuestion.some((row) => Number(row.user_id) === currentUserId)) {
        mineQuestionIds.add(String(questionId));
      }
    }); %>
  <% } %>
  <% Object.entries(guestViewerAnswers).forEach(([questionId, answer]) => {
    if (String(answer || '').trim() !== '') mineQuestionIds.add(String(questionId));
  }); %>
  <% const displayQuestions = showMine ? questions.filter((q) => mineQuestionIds.has(String(q.id))) : questions; %>
  <% const formatPercent = (value) => {
      const rounded = Math.round(Number(value || 0) * 10) / 10;
      return Number.isInteger(rounded) ? String(rounded) : rounded.toFixed(1);
    }; %>
  <% const escapeHtml = (value) =>
      String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;'); %>
  <% const buildPromptTooltipHtml = (questionObj) => {
      const text = String(questionObj?.prompt || '');
      if (!text) return '';
      const questionId = String(questionObj?.id || '');

      const termDefs = [
        {
          tip: t('questions.tip_dnf'),
          patterns: [/\bDNF(?:'s|s)?\b/gi]
        },
        {
          tip: t('questions.tip_dns'),
          patterns: [/\bDNS\b/gi]
        },
        {
          tip: t('questions.tip_dq'),
          patterns: [/\bDSQ\b/gi]
        },
        {
          tip: t('questions.tip_grand_prix'),
          patterns: [/\bGrand Prix\b/gi]
        }
      ];

      if (questionId === 'drivers_championship_last') {
        termDefs.push({
          tip: t('questions.tip_initial_lineup'),
          patterns: [/\bdriver\b/gi, /\bcoureur\b/gi, /\bfahrer\b/gi, /\bpiloto\b/gi, /\bpilote\b/gi]
        });
      }
      if (
        questionId === 'all_podium_finishers' ||
        questionId === 'mini_q3_ferrari_podium' ||
        questionId === 'most_points_no_podium'
      ) {
        termDefs.push({
          tip: t('questions.tip_podium_gp_only'),
          patterns: [/\bpodium(?:s)?\b/gi, /\bpodiumfinishers?\b/gi, /\bpodiumsfahrer\b/gi, /\bpodio(?:s)?\b/gi]
        });
      }
      if (questionId === 'lowest_grid_win_position') {
        termDefs.push({
          tip: t('questions.tip_race_gp_wins_only'),
          patterns: [/\brace(?:s)?\b/gi, /\brennen\b/gi, /\bcarrera(?:s)?\b/gi, /\bcourse(?:s)?\b/gi]
        });
      }
      if (questionId === 'select_three_races_dnfs' || questionId === 'races_before_title_decided') {
        termDefs.push({
          tip: t('questions.tip_races_grand_prix_only'),
          patterns: [/\braces\b/gi, /\brennen\b/gi, /\bcarreras\b/gi, /\bcourses\b/gi]
        });
      }
      if (questionId === 'mini_q2_mercedes_engines_top5') {
        termDefs.push({
          tip: t('questions.tip_mercedes_engine_teams'),
          patterns: [
            /\bteams with Mercedes engines\b/gi,
            /\bteams met Mercedes-motoren\b/gi,
            /\bteams mit Mercedes-Motor\b/gi,
            /\bequipos con motor Mercedes\b/gi,
            /\bequipes a moteur Mercedes\b/gi
          ]
        });
      }
      if (questionId === 'destructors_driver' || questionId === 'destructors_team') {
        termDefs.push({
          tip: t('questions.tip_damage_source'),
          patterns: [/\bdamage\b/gi, /\bschade\b/gi, /\bschaden\b/gi, /\bdanos\b/gi, /\bdegats\b/gi]
        });
      }

      const matches = [];
      termDefs.forEach((def, defIndex) => {
        def.patterns.forEach((regex) => {
          const flags = regex.flags.includes('g') ? regex.flags : `${regex.flags}g`;
          const re = new RegExp(regex.source, flags);
          let match = re.exec(text);
          while (match) {
            if (match[0]) {
              matches.push({
                start: match.index,
                end: match.index + match[0].length,
                label: match[0],
                tip: def.tip,
                defIndex
              });
            }
            if (re.lastIndex === match.index) {
              re.lastIndex += 1;
            }
            match = re.exec(text);
          }
        });
      });

      if (!matches.length) return escapeHtml(text);

      matches.sort((a, b) => {
        if (a.start !== b.start) return a.start - b.start;
        const aLen = a.end - a.start;
        const bLen = b.end - b.start;
        if (aLen !== bLen) return bLen - aLen;
        return a.defIndex - b.defIndex;
      });

      const selected = [];
      let lastEnd = -1;
      matches.forEach((match) => {
        if (match.start < lastEnd) return;
        selected.push(match);
        lastEnd = match.end;
      });

      let out = '';
      let cursor = 0;
      selected.forEach((match) => {
        out += escapeHtml(text.slice(cursor, match.start));
        out += `<span class="question-term" tabindex="0"><span class="question-term-label">${escapeHtml(match.label)}</span><span class="question-term-tooltip">${escapeHtml(match.tip)}</span></span>`;
        cursor = match.end;
      });
      out += escapeHtml(text.slice(cursor));
      return out;
    }; %>
  <% const isHumanReadableSourceUrl = (url) => {
      if (!url || typeof url !== 'string') return false;
      const value = url.trim();
      if (!/^https?:\/\//i.test(value)) return false;
      const lower = value.toLowerCase();
      if (lower.includes('api.jolpi.ca')) return false;
      if (lower.includes('/ergast/')) return false;
      if (lower.endsWith('.json') || lower.includes('.json?')) return false;
      return true;
    }; %>
  <% const formatLastSeasonResult = (entry) => {
      if (!entry || typeof entry !== 'object') return '';
      const parts = [];
      const addValue = (value) => {
        if (Array.isArray(value)) {
          value.forEach(addValue);
          return;
        }
        const text = String(value || '').trim();
        if (!text) return;
        parts.push(text);
      };

      const hasExplicitResults = Array.isArray(entry.results) && entry.results.length > 0;
      if (hasExplicitResults) {
        addValue(entry.results);
      } else {
        addValue(entry.result);
      }

      const seen = new Set();
      const unique = parts.filter((value) => {
        const key = value.toLocaleLowerCase();
        if (seen.has(key)) return false;
        seen.add(key);
        return true;
      });
      if (unique.length === 0) return t('questions.last_season_default_result');
      return unique.join(' / ');
    }; %>
  <% const parseArrayAnswer = (value) => {
      try {
        const parsed = JSON.parse(value);
        return Array.isArray(parsed) ? parsed : [];
      } catch (err) {
        return [];
      }
    }; %>
  <% const formatAnswer = (row) => {
      const q = questionMap[row.question_id];
      let answerText = row.answer;
      if (q && (q.type === 'ranking' || q.type === 'multi_select' || q.type === 'multi_select_limited')) {
        try {
          const items = JSON.parse(row.answer);
          if (Array.isArray(items)) {
            answerText = q.type === 'ranking' ? items.join(' > ') : items.join(', ');
          }
        } catch (err) {}
      }
      if (q && q.type === 'boolean') {
        answerText = row.answer === 'yes' ? yesText : row.answer === 'no' ? noText : row.answer;
      }
      if (q && (q.type === 'teammate_battle' || q.type === 'boolean_with_optional_driver' || q.type === 'numeric_with_driver' || q.type === 'single_choice_with_driver')) {
        try {
          const obj = JSON.parse(row.answer);
          if (q.type === 'teammate_battle') {
            const winner = obj.winner === 'tie' ? tieText : (obj.winner || naText);
            answerText = `${winner} (${t('responses.diff_label')}: ${obj.diff ?? naText})`;
          }
          if (q.type === 'boolean_with_optional_driver') {
            const choice = obj.choice === 'yes' ? yesText : obj.choice === 'no' ? noText : (obj.choice || naText);
            answerText = `${choice}${obj.driver ? ` - ${obj.driver}` : ''}`;
          }
          if (q.type === 'numeric_with_driver' || q.type === 'single_choice_with_driver') {
            answerText = `${obj.value ?? naText}${obj.driver ? ` - ${obj.driver}` : ''}`;
          }
        } catch (err) {}
      }
      return answerText;
    }; %>
  <% const focusedRowsByQuestion = focusedMemberResponsesData.reduce((acc, row) => {
      if (row && row.question_id) acc[row.question_id] = row;
      return acc;
    }, {}); %>
  <% const summarizeAnswers = (rows) => {
      const counts = new Map();
      rows.forEach((row) => {
        const label = formatAnswer(row);
        counts.set(label, (counts.get(label) || 0) + 1);
      });
      const total = rows.length;
      return Array.from(counts.entries())
        .map(([label, count]) => ({
          label,
          count,
          percent: total > 0 ? (count * 100) / total : 0
        }))
        .sort((a, b) => {
          if (b.count !== a.count) return b.count - a.count;
          return a.label.localeCompare(b.label);
        });
    }; %>
  <% const summarizeMultiSelectOptions = (rows) => {
      const counts = new Map();
      rows.forEach((row) => {
        const seen = new Set();
        const items = parseArrayAnswer(row.answer);
        items.forEach((item) => {
          const label = String(item || '').trim();
          if (!label || seen.has(label)) return;
          seen.add(label);
          counts.set(label, (counts.get(label) || 0) + 1);
        });
      });
      const total = rows.length;
      return Array.from(counts.entries())
        .map(([label, count]) => ({
          label,
          count,
          percent: total > 0 ? (count * 100) / total : 0
        }))
        .sort((a, b) => {
          if (b.count !== a.count) return b.count - a.count;
          return a.label.localeCompare(b.label);
        });
    }; %>
  <% const summarizeRankingByPlace = (rows, question) => {
      const placeCount = Number(question?.count || 0) || 3;
      const buckets = Array.from({ length: placeCount }, () => new Map());
      rows.forEach((row) => {
        let picks = [];
        try {
          const parsed = JSON.parse(row.answer);
          if (Array.isArray(parsed)) picks = parsed;
        } catch (err) {}
        for (let i = 0; i < placeCount; i += 1) {
          const pick = picks[i];
          if (!pick) continue;
          buckets[i].set(pick, (buckets[i].get(pick) || 0) + 1);
        }
      });
      const total = rows.length;
      return buckets.map((bucket) =>
        Array.from(bucket.entries())
          .map(([label, count]) => ({
            label,
            count,
            percent: total > 0 ? (count * 100) / total : 0
          }))
          .sort((a, b) => {
            if (b.count !== a.count) return b.count - a.count;
            return a.label.localeCompare(b.label);
          })
      );
    }; %>
  <% const limitRowsWithViewer = (items, viewerLabel, limit = 5) => {
      const top = items.slice(0, limit);
      if (!viewerLabel) return top;
      const inTop = top.some((item) => item.label === viewerLabel);
      if (inTop) return top;
      const viewerItem = items.find((item) => item.label === viewerLabel);
      if (!viewerItem) return top;
      if (top.length < limit) return top.concat([viewerItem]);
      if (limit <= 1) return [viewerItem];
      return top.slice(0, limit - 1).concat([viewerItem]);
    }; %>
  <% const limitRowsWithViewerSet = (items, viewerLabels, limit = 5) => {
      const top = items.slice(0, limit);
      const labels = Array.isArray(viewerLabels) ? viewerLabels : [];
      if (labels.length === 0) return top;
      const topLabelSet = new Set(top.map((item) => item.label));
      const viewerItem = labels
        .map((label) => items.find((item) => item.label === label))
        .find((item) => item && !topLabelSet.has(item.label));
      if (!viewerItem) return top;
      if (top.length < limit) return top.concat([viewerItem]);
      if (limit <= 1) return [viewerItem];
      return top.slice(0, limit - 1).concat([viewerItem]);
    }; %>

  <% if (responses.length === 0 || displayQuestions.length === 0) { %>
    <div class="alert"><%= t('responses.no_responses') %></div>
  <% } else { %>
    <% displayQuestions.forEach(q => { %>
      <% const lastSeason = q.last_season || null; %>
      <% const hasLastSeasonReference = Boolean(lastSeason); %>
      <% const lastSeasonResult = hasLastSeasonReference ? formatLastSeasonResult(lastSeason) : ''; %>
      <% const lastSeasonUrl = String(lastSeason?.url || '').trim(); %>
      <% const lastSeasonLabel = String(lastSeason?.label || '').trim(); %>
      <% const lastSeasonSourceUrl = isHumanReadableSourceUrl(lastSeasonUrl) ? lastSeasonUrl : ''; %>
      <% const hasLastSeasonDetails = hasLastSeasonReference && Boolean(lastSeasonResult || lastSeasonSourceUrl); %>
      <div class="responses-section">
        <div class="responses-question-head">
          <h3 class="survey-question-title"><%- buildPromptTooltipHtml(q) %></h3>
          <% if (hasLastSeasonDetails) { %>
            <div class="question-last-season-peek" tabindex="0">
              <span class="question-last-season-toggle"><%= t('questions.last_season_link') %></span>
              <div class="question-last-season-panel">
                <% if (lastSeasonResult) { %>
                  <div class="question-last-season-result"><%= lastSeasonResult %></div>
                <% } %>
                <% if (lastSeasonSourceUrl) { %>
                  <a
                    class="link question-last-season-source"
                    href="<%= lastSeasonSourceUrl %>"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <%= lastSeasonLabel || lastSeasonSourceUrl %>
                  </a>
                <% } %>
              </div>
            </div>
          <% } %>
        </div>
        <% const rows = responsesByQuestion[q.id] || []; %>
        <% if (rows.length === 0) { %>
          <p class="muted"><%= t('responses.no_responses') %></p>
        <% } else { %>
          <% const memberViewerRow = rows.find((row) => Number(row.user_id) === currentUserId) || null; %>
          <% const guestViewerRawAnswer = String(guestViewerAnswers[q.id] || ''); %>
          <% const viewerRow = memberViewerRow || (guestViewerRawAnswer
            ? { user_id: 0, question_id: q.id, answer: guestViewerRawAnswer }
            : null); %>
          <% const focusedRow = focusedRowsByQuestion[q.id] || null; %>
          <% const hasFocusedMember = !showMine && Boolean(focusedMemberData); %>
          <% const viewerAnswerLabel = viewerRow ? formatAnswer(viewerRow) : ''; %>
          <% const focusedAnswerLabel = focusedRow ? formatAnswer(focusedRow) : ''; %>
          <% const viewerBooleanChoice = q.type === 'boolean' && viewerRow ? String(viewerRow.answer || '') : ''; %>
          <% const focusedBooleanChoice = q.type === 'boolean' && focusedRow ? String(focusedRow.answer || '') : ''; %>
          <% const viewerMultiSelectPicks = (q.type === 'multi_select' || q.type === 'multi_select_limited') && viewerRow ? parseArrayAnswer(viewerRow.answer) : []; %>
          <% const focusedMultiSelectPicks = (q.type === 'multi_select' || q.type === 'multi_select_limited') && focusedRow ? parseArrayAnswer(focusedRow.answer) : []; %>
          <% const viewerRankingPicks = q.type === 'ranking' && viewerRow ? parseArrayAnswer(viewerRow.answer) : []; %>
          <% const focusedRankingPicks = q.type === 'ranking' && focusedRow ? parseArrayAnswer(focusedRow.answer) : []; %>
          <% const activeAnswerLabel = hasFocusedMember ? focusedAnswerLabel : viewerAnswerLabel; %>
          <% const activeBooleanChoice = hasFocusedMember ? focusedBooleanChoice : viewerBooleanChoice; %>
          <% const activeMultiSelectPicks = hasFocusedMember ? focusedMultiSelectPicks : viewerMultiSelectPicks; %>
          <% const activeRankingPicks = hasFocusedMember ? focusedRankingPicks : viewerRankingPicks; %>
          <% const activeChoiceClass = hasFocusedMember ? 'is-focused-choice' : 'is-viewer-choice'; %>
          <% const isFullMultiColumnSummary = q.id === 'all_podium_finishers' || q.id === 'select_three_races_dnfs'; %>
          <% const summary = isFullMultiColumnSummary ? summarizeMultiSelectOptions(rows) : summarizeAnswers(rows); %>
          <% const summaryDisplayRows = isFullMultiColumnSummary
            ? (showMine
              ? summary.filter((item) => activeMultiSelectPicks.includes(item.label))
              : limitRowsWithViewerSet(summary, activeMultiSelectPicks, 5))
            : (q.type === 'boolean' || q.type === 'ranking'
              ? summary
              : (showMine
                ? summary.filter((item) => activeAnswerLabel && item.label === activeAnswerLabel)
                : limitRowsWithViewer(summary, activeAnswerLabel, 5))); %>
          <% const yesCount = q.type === 'boolean' ? rows.filter((row) => row.answer === 'yes').length : 0; %>
          <% const noCount = q.type === 'boolean' ? rows.filter((row) => row.answer === 'no').length : 0; %>
          <% const yesPercent = rows.length > 0 ? (yesCount * 100) / rows.length : 0; %>
          <% const noPercent = rows.length > 0 ? (noCount * 100) / rows.length : 0; %>
          <% const showYesRow = !showMine || activeBooleanChoice === 'yes'; %>
          <% const showNoRow = !showMine || activeBooleanChoice === 'no'; %>
          <% const rankingByPlace = q.type === 'ranking' ? summarizeRankingByPlace(rows, q) : []; %>
          <div class="responses-summary">
            <div class="muted responses-summary-title">
              <%= t('responses.summary_title') %> &middot; <%= rows.length %> <%= t('responses.response_count_label') %>
            </div>
            <% if (q.type === 'boolean') { %>
              <div class="responses-yesno-head">
                <% if (showYesRow) { %>
                  <span class="<%= activeBooleanChoice === 'yes' ? activeChoiceClass : '' %>"><%= yesText %> &middot; <%= formatPercent(yesPercent) %>% (<%= yesCount %>)</span>
                <% } %>
                <% if (showNoRow) { %>
                  <span class="<%= activeBooleanChoice === 'no' ? activeChoiceClass : '' %>"><%= noText %> &middot; <%= formatPercent(noPercent) %>% (<%= noCount %>)</span>
                <% } %>
              </div>
              <div class="responses-yesno-track" aria-hidden="true">
                <% if (showYesRow) { %>
                  <span class="responses-yesno-yes <%= activeBooleanChoice === 'yes' ? activeChoiceClass : '' %>" style="width:<%= yesPercent %>%;"></span>
                <% } %>
                <% if (showNoRow) { %>
                  <span class="responses-yesno-no <%= activeBooleanChoice === 'no' ? activeChoiceClass : '' %>" style="width:<%= noPercent %>%;"></span>
                <% } %>
              </div>
            <% } else if (q.type === 'ranking') { %>
              <div class="responses-ranking-splits">
                <% rankingByPlace.forEach((placeRows, index) => { %>
                  <% if (placeRows.length > 0) { %>
                    <% const viewerPlacePick = activeRankingPicks[index]; %>
                    <% const placeDisplayRows = showMine
                      ? placeRows.filter((item) => viewerPlacePick && item.label === viewerPlacePick)
                      : limitRowsWithViewer(placeRows, viewerPlacePick, 5); %>
                    <div class="responses-ranking-place">
                      <div class="muted responses-ranking-place-title"><%= t('responses.position_label', { n: index + 1 }) %></div>
                      <ul class="responses-bars">
                        <% placeDisplayRows.forEach(item => { %>
                          <li class="responses-bars-item <%= activeRankingPicks[index] === item.label ? activeChoiceClass : '' %>">
                            <span class="responses-bars-label"><%= item.label %></span>
                            <span class="responses-bars-track" aria-hidden="true">
                              <span class="responses-bars-fill" style="width:<%= item.percent %>%;"></span>
                            </span>
                            <span class="responses-bars-value"><%= formatPercent(item.percent) %>% (<%= item.count %>)</span>
                          </li>
                        <% }) %>
                      </ul>
                    </div>
                  <% } %>
                <% }) %>
              </div>
            <% } else if (isFullMultiColumnSummary) { %>
              <ul class="responses-podium-columns">
                <% summaryDisplayRows.forEach(item => { %>
                  <% const isViewerChoice = activeMultiSelectPicks.includes(item.label); %>
                  <li class="responses-podium-item <%= isViewerChoice ? activeChoiceClass : '' %>">
                    <span class="responses-podium-label"><%= item.label %></span>
                    <span class="responses-podium-value"><%= formatPercent(item.percent) %>% (<%= item.count %>)</span>
                  </li>
                <% }) %>
              </ul>
            <% } else { %>
              <ul class="responses-bars">
                <% summaryDisplayRows.forEach(item => { %>
                  <% const isViewerChoice = activeAnswerLabel && item.label === activeAnswerLabel; %>
                  <li class="responses-bars-item <%= isViewerChoice ? activeChoiceClass : '' %>">
                    <span class="responses-bars-label"><%= item.label %></span>
                    <span class="responses-bars-track" aria-hidden="true">
                      <span class="responses-bars-fill" style="width:<%= item.percent %>%;"></span>
                    </span>
                    <span class="responses-bars-value"><%= formatPercent(item.percent) %>% (<%= item.count %>)</span>
                  </li>
                <% }) %>
              </ul>
            <% } %>
          </div>
        <% } %>
      </div>
    <% }) %>
  <% } %>
</div>

<script>
  (function () {
    const terms = Array.from(document.querySelectorAll(".question-term"));
    if (terms.length === 0) return;

    const setShift = (term, shiftPx) => {
      const tip = term.querySelector(".question-term-tooltip");
      if (!tip) return;
      tip.style.setProperty("--tooltip-shift", `${Math.round(shiftPx)}px`);
    };

    const clearShift = (term) => setShift(term, 0);

    const adjustShift = (term) => {
      const tip = term.querySelector(".question-term-tooltip");
      if (!tip) return;
      clearShift(term);
      const margin = 8;
      const rect = tip.getBoundingClientRect();
      let shift = 0;
      if (rect.right > window.innerWidth - margin) {
        shift -= rect.right - (window.innerWidth - margin);
      }
      if (rect.left < margin) {
        shift += margin - rect.left;
      }
      setShift(term, shift);
    };

    terms.forEach((term) => {
      term.addEventListener("mouseenter", () => adjustShift(term));
      term.addEventListener("focusin", () => adjustShift(term));
      term.addEventListener("mouseleave", () => clearShift(term));
      term.addEventListener("focusout", (event) => {
        if (event.relatedTarget && term.contains(event.relatedTarget)) return;
        clearShift(term);
      });
    });

    window.addEventListener("resize", () => {
      terms.forEach((term) => {
        if (term.matches(":hover") || term.contains(document.activeElement)) {
          adjustShift(term);
        }
      });
    });
  })();

  (function () {
    const toggle = document.querySelector('[data-responses-mine-toggle]');
    if (!toggle) return;
    toggle.addEventListener('change', () => {
      const url = new URL(window.location.href);
      if (toggle.checked) {
        url.searchParams.set('mine', '1');
        url.searchParams.delete('focusUserId');
        url.searchParams.delete('focusGuestId');
      } else {
        url.searchParams.delete('mine');
      }
      window.location.assign(url.toString());
    });
  })();
</script>

