{
  "name": "f1-predictions-2026",
  "version": "0.1.0",
  "description": "Group-based F1 2026 prediction game",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "start:dev": "node --watch --watch-path=server.js --watch-path=src --watch-path=views --watch-path=public --watch-path=locales --watch-preserve-output server.js",
    "lint": "node scripts/check-js-syntax.js",
    "typecheck": "npm run lint",
    "test": "node --test tests/*.test.js",
    "test:e2e": "playwright test",
    "build": "node scripts/check-production-assets.js",
    "db:migrate:postgres": "node scripts/migrate-sqlite-to-postgres.js",
    "actuals:auto-update": "node scripts/backfill-actuals-2026.js --dry-run",
    "actuals:auto-apply": "node scripts/backfill-actuals-2026.js --apply",
    "analyze:balance": "node scripts/analyze-balance.js",
    "build:last-season-results": "node scripts/build-last-season-results.js"
  },
  "engines": {
    "node": "20.x || 22.x || 23.x || 24.x"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.10.0",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-session": "^1.17.3",
    "helmet": "^8.2.0",
    "nodemailer": "^9.0.1",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
